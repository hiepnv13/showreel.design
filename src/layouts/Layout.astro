---
import SmoothScroll from '../components/SmoothScroll.astro';
import Preloader from '../components/Preloader.astro';
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Discover amazing motion design and animation work from talented creators worldwide." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="view-transition" content="same-origin" />
    <title>{title}</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <!-- Inline: apply dark class before paint to avoid FOUC -->
    <script is:inline>
      if (localStorage.getItem('darkMode') === 'true') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body>
    <Preloader />
    <slot />
    <SmoothScroll />
  </body>
</html>

<script>
  // Import page transitions
  import '../scripts/pageTransitions.js';
</script>
