---
export interface Props {
  name: string;
  category: string;
  description: string;
  pricing: string;
  href: string;
  thumbnail?: string;
  tags?: { label: string; color: string }[];
}

const { name, description, pricing, href, thumbnail, tags = [] } = Astro.props;

const colorMap: Record<string, { bg: string; text: string }> = {
  blue:   { bg: '#dbeafe', text: '#1d4ed8' },
  green:  { bg: '#dcfce7', text: '#16a34a' },
  orange: { bg: '#ffedd5', text: '#ea580c' },
  purple: { bg: '#f3e8ff', text: '#9333ea' },
  gray:   { bg: '#f5f5f5', text: '#888888' },
};
---

<a href={href} target="_blank" rel="noopener noreferrer" class="tool-card group cursor-pointer block">
  <div class="tool-frame">
    <img
      src={thumbnail || '/placeholder.svg'}
      alt={name}
      class="tool-thumbnail"
      loading="lazy"
    />
  </div>

  <div class="tool-info">
    <div class="tool-meta">
      <p class="tool-name">{name}</p>
      <p class="tool-pricing">{pricing}</p>
    </div>
    <p class="tool-description">{description}</p>
    {tags.length > 0 && (
      <div class="tool-tags">
        {tags.map((tag) => {
          const color = colorMap[tag.color] ?? colorMap.gray;
          return (
            <span class="tool-tag" style={`background:${color.bg};color:${color.text}`}>
              {tag.label}
            </span>
          );
        })}
      </div>
    )}
  </div>
</a>

<style>
  .tool-card {
    text-decoration: none;
  }

  .tool-frame {
    position: relative;
    border-radius: 12px;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e8e8;
    transition: opacity 0.2s;
  }

  .tool-card:hover .tool-frame {
    opacity: 0.9;
  }

  .tool-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tool-info {
    padding: 10px 2px 12px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .tool-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }

  .tool-name {
    font-size: 15px;
    font-weight: 500;
    color: #1b1b1b;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .tool-pricing {
    font-size: 11px;
    color: #bbb;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tool-description {
    font-size: 12px;
    line-height: 1.6;
    color: #888;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 2px;
  }

  .tool-tag {
    font-size: 10px;
    letter-spacing: 0.2px;
    padding: 2px 8px;
    border-radius: 20px;
    font-weight: 500;
  }
</style>
