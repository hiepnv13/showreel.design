---
import VideoCard from "./VideoCard.astro";
import Pagination from "./Pagination.astro";
import { getAllVideos, sortVideosByDate } from "../utils/videoUtils";

interface Props {
    videos?: any[];
    currentPage?: number;
    itemsPerPage?: number;
    baseUrl?: string;
    filter?: string;
}

const {
    videos: propsVideos,
    currentPage = 1,
    itemsPerPage = 24,
    baseUrl = "/",
    filter = "",
} = Astro.props;

const allVideos = propsVideos || sortVideosByDate(await getAllVideos());

const totalPages = Math.ceil(allVideos.length / itemsPerPage);
const startIndex = (currentPage - 1) * itemsPerPage;
const displayVideos = allVideos.slice(startIndex, startIndex + itemsPerPage);
---

<main class="w-full bg-white video-grid px-4 sm:px-8 pt-8 pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {
            displayVideos.map((video: any) => (
                <VideoCard
                    title={video.data.title}
                    author={video.data.author}
                    authorAvatar={video.data.authorAvatar}
                    thumbnail={video.data.thumbnail}
                    videoUrl={video.data.thumbnailUrl}
                    slug={video.id}
                    industries={video.data.industries ?? []}
                    styles={video.data.styles ?? []}
                    soundMusic={video.data.soundMusic ?? []}
                />
            ))
        }
    </div>

    <!-- Pagination -->
    <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        baseUrl={baseUrl}
        filter={filter}
    />
</main>

<script>
    // Import grid actions for interactive animations
    import "../scripts/gridActions.js";
</script>