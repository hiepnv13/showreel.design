---
import { getAllVideos, getAllCategories, generateSlug } from '../utils/videoUtils';

const currentPath = Astro.url.pathname;

const allVideos = await getAllVideos();
const totalCount = allVideos.length;
const allCategories = await getAllCategories();

const categoryCounts = new Map<string, number>();
for (const cat of allCategories) {
  categoryCounts.set(cat, allVideos.filter((v: any) => v.data.category === cat).length);
}

const isHome = currentPath === '/' || currentPath.startsWith('/page/');
const isAboutActive = currentPath === '/about';

---

<!-- Mobile overlay -->
<div class="sidebar-overlay" id="sidebar-overlay"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-inner">

    <!-- Close button (mobile only) -->
    <button class="sidebar-close" id="sidebar-close" aria-label="Close menu">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M18 6L6 18M6 6l12 12"/>
      </svg>
    </button>

    <!-- Logo -->
    <a href="/" class="sidebar-logo">
      <span>Showreel</span>
      <span>.Design</span>
    </a>

    <!-- Main nav: Category + Resource sections -->
    <div class="sidebar-sections">

      <!-- Category section -->
      <div class="sidebar-section">
        <p class="sidebar-section-label">Category</p>
        <nav class="sidebar-nav">
          <a href="/" class={`sidebar-item sidebar-item-icon ${isHome ? 'active' : ''}`}>
            <img src="/uploads/more-03.svg" class="nav-icon" alt="" />
            <span class="nav-label">All</span>
            <span class="sidebar-badge badge-hover">{totalCount}</span>
          </a>
          {allCategories.map((cat) => {
            const slug = generateSlug(cat);
            const isActive = currentPath.includes(`/category/${slug}`);
            const iconMap: {[key: string]: string} = {
              'Motion Graphics':    'ease-curve-control-points',
              '3D / CGI':           '3d-view',
              'Studio / Agency':    'global',
              'Branding & Identity':'pen-tool-03',
              'UI/UX Motion':       'web-design-02',
            };
            const icon = iconMap[cat] ?? 'more-03';
            return (
              <a href={`/category/${slug}`} class={`sidebar-item sidebar-item-icon ${isActive ? 'active' : ''}`}>
                <img src={`/uploads/${icon}.svg`} class="nav-icon" alt="" />
                <span class="nav-label">{cat}</span>
                <span class="sidebar-badge badge-hover">{categoryCounts.get(cat) ?? 0}</span>
              </a>
            );
          })}
        </nav>
      </div>

      <!-- Resource section — hidden until content is ready
      <div class="sidebar-section">
        <p class="sidebar-section-label">Resource</p>
        <nav class="sidebar-nav">
          <a href="/resources/tools" class={`sidebar-item sidebar-item-icon ${currentPath.startsWith('/resources/tools') ? 'active' : ''}`}>
            <img src="/uploads/cursor-edit-02.svg" class="nav-icon" alt="" />
            <span class="nav-label">Tools</span>
          </a>
          <a href="/resources/courses" class={`sidebar-item sidebar-item-icon ${currentPath.startsWith('/resources/courses') ? 'active' : ''}`}>
            <img src="/uploads/canvas.svg" class="nav-icon" alt="" />
            <span class="nav-label">Courses</span>
          </a>
        </nav>
      </div>
      -->

    </div>

    <!-- Spacer -->
    <div class="sidebar-spacer"></div>

    <!-- Footer nav -->
    <div class="sidebar-footer">
      <a href="/about" class={`sidebar-item ${isAboutActive ? 'active' : ''}`}>About Us</a>

      <!-- Follow Us on X -->
      <a href="https://x.com/showreeldesign" target="_blank" rel="noopener noreferrer" class="sidebar-item">Follow Us on X</a>

      <!-- Partner banner slider -->
      <div class="sidebar-partner">
        <span class="sidebar-partner-label">Partner</span>
        <div class="partner-slider" id="partner-slider">
          <div class="partner-track" id="partner-track">
            <a href="https://framer.link/srd" target="_blank" rel="noopener noreferrer" class="partner-slide">
              <img src="/uploads/Partner_Framer.png" alt="Framer Templates" loading="lazy" />
              <span class="slide-tooltip">Framer Templates</span>
            </a>
            <a href="https://www.lapa.ninja?ref=showreel.design" target="_blank" rel="noopener noreferrer" class="partner-slide">
              <img src="/uploads/Partner_Lapa.png" alt="Lapa.ninja" loading="lazy" />
              <span class="slide-tooltip">Lapa.ninja</span>
            </a>
            <a href="https://www.landing.love?ref=showreel.design" target="_blank" rel="noopener noreferrer" class="partner-slide">
              <img src="/uploads/Partner_Landing.png" alt="Landing.love" loading="lazy" />
              <span class="slide-tooltip">Landing.love</span>
            </a>
            <a href="https://mobbin.com/?via=showreeldesign" target="_blank" rel="noopener noreferrer" class="partner-slide">
              <img src="/uploads/Partner_Mobbin.png" alt="Mobbin" loading="lazy" />
              <span class="slide-tooltip">Mobbin — UI & UX Library</span>
            </a>
          </div>

          <button class="slider-btn slider-prev" id="slider-prev" aria-label="Previous">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <button class="slider-btn slider-next" id="slider-next" aria-label="Next">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>

          <div class="slider-dots" id="slider-dots">
            <button class="slider-dot active" data-index="0"></button>
            <button class="slider-dot" data-index="1"></button>
            <button class="slider-dot" data-index="2"></button>
            <button class="slider-dot" data-index="3"></button>
          </div>
        </div>
      </div>

      <!-- Copyright -->
      <div class="sidebar-copyright">
        <div class="sidebar-copyright-divider"></div>
        <p class="sidebar-copyright-text">All showreel © of their respective owners</p>
      </div>

    </div>

  </div>
</aside>

<script>
  // Partner slider
  const slider = document.getElementById('partner-slider');
  const track  = document.getElementById('partner-track');
  const dots   = document.querySelectorAll('#slider-dots .slider-dot');
  const prevBtn = document.getElementById('slider-prev');
  const nextBtn = document.getElementById('slider-next');
  const total = dots.length;
  let current = 0;
  let autoTimer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = (index + total) % total;
    if (track) (track as HTMLElement).style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => d.classList.toggle('active', i === current));
  }

  function startAuto() {
    autoTimer = setInterval(() => goTo(current + 1), 5000);
  }

  function stopAuto() {
    clearInterval(autoTimer);
  }

  prevBtn?.addEventListener('click', (e) => { e.preventDefault(); stopAuto(); goTo(current - 1); startAuto(); });
  nextBtn?.addEventListener('click', (e) => { e.preventDefault(); stopAuto(); goTo(current + 1); startAuto(); });
  dots.forEach(dot => dot.addEventListener('click', () => { stopAuto(); goTo(Number((dot as HTMLElement).dataset.index)); startAuto(); }));
  slider?.addEventListener('mouseenter', stopAuto);
  slider?.addEventListener('mouseleave', startAuto);

  startAuto();


</script>

<style>
  /* ── Overlay ── */
  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 90;
  }

  .sidebar-overlay.open {
    display: block;
  }

  /* ── Close button (mobile only) ── */
  .sidebar-close {
    display: none;
  }

  /* ── Sidebar ── */
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    width: 209px;
    z-index: 100;
    transition: transform 0.3s ease;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 12px;
    background: #fff;
    border-right: 1px solid #f0f0f0;
    overflow-y: auto;
  }

  /* ── Logo ── */
  .sidebar-logo {
    display: flex;
    flex-direction: column;
    font-size: 20px;
    font-weight: 700;
    line-height: 0.97;
    color: #000;
    text-decoration: none;
    margin-bottom: 32px;
    flex-shrink: 0;
    letter-spacing: -0.3px;
  }

  .sidebar-logo:hover { opacity: 0.7; }

  /* ── Sections ── */
  .sidebar-sections {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sidebar-section-label {
    font-size: 12px;
    color: #a4a4a4;
    line-height: 1.191;
    margin: 0;
    padding: 0 8px;
  }

  /* ── Nav items ── */
  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-item {
    font-size: 13px;
    color: #555;
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    line-height: 1.191;
    background: none;
    border: none;
    padding: 0 8px;
    cursor: pointer;
    text-align: left;
    width: 100%;
    font-family: 'Aileron', sans-serif;
    border-radius: 8px;
    height: 32px;
    display: flex;
    align-items: center;
  }

  .sidebar-item:hover {
    color: #222;
    background: rgba(90, 90, 90, 0.04);
  }

  .sidebar-item.active {
    color: #111;
    background: rgba(90, 90, 90, 0.06);
    box-shadow:
      0px -1px 0px 0px rgba(255,255,255,0.35),
      1px  0px 0px 0px rgba(255,255,255,0.15),
      -1px 0px 0px 0px rgba(255,255,255,0.15),
      0px  1px 0px 0px rgba(255,255,255,0.30),
      0px  1px 1px 0px rgba(0,0,0,0.20);
  }

  .sidebar-item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  /* Icon nav items */
  .sidebar-item-icon {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    opacity: 0.5;
    transition: opacity 0.15s;
  }

  .sidebar-item-icon:hover .nav-icon { opacity: 0.7; }
  .sidebar-item-icon.active .nav-icon { opacity: 0.7; }

  /* Badge — hover-only for category items */
  .badge-hover {
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .sidebar-item-icon:hover .badge-hover,
  .sidebar-item-icon.active .badge-hover {
    visibility: visible;
    opacity: 1;
  }

  .nav-label {
    flex: 1;
    min-width: 0;
  }

  .sidebar-badge {
    background: #ececec;
    color: #5c5c5c;
    font-size: 10px;
    letter-spacing: -0.2px;
    padding: 2px 4px;
    border-radius: 5px;
    line-height: 1.4;
    flex-shrink: 0;
  }

  .badge-hidden {
    visibility: hidden;
  }

  /* ── Spacer ── */
  .sidebar-spacer {
    flex: 1;
    min-height: 32px;
  }

  /* ── Footer ── */
  .sidebar-footer {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 20px;
    border-top: 1px solid #f0f0f0;
    flex-shrink: 0;
  }


  /* ── Partner logos ── */
  .sidebar-partner {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sidebar-partner-label {
    font-size: 13px;
    color: #000;
    opacity: 0.4;
    line-height: 1.191;
    padding-left: 8px;
  }

  .sidebar-partner-logos {
    display: flex;
    gap: 10px;
    align-items: center;
  }

  .partner-logo-wrap {
    position: relative;
    display: block;
    flex-shrink: 0;
  }

  .partner-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.15s;
  }

  .partner-logo-wrap:hover .partner-logo {
    opacity: 0.85;
  }

  .partner-logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Tooltip */
  .partner-tooltip {
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #111;
    color: #fff;
    font-size: 10px;
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 10;
  }

  .partner-logo-wrap:hover .partner-tooltip {
    opacity: 1;
  }

  /* First logo in each row — tooltip aligns left to avoid overflow */
  .partner-logo-wrap:first-child .partner-tooltip {
    left: 0;
    transform: none;
  }

  /* ── Partner slider ── */
  .partner-slider {
    position: relative;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .partner-track {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .partner-slide {
    flex: 0 0 100%;
    width: 100%;
    display: block;
    position: relative;
  }

  .partner-slide img {
    width: 100%;
    height: auto;
    display: block;
  }

  .slide-tooltip {
    position: absolute;
    bottom: 8px;
    left: 8px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: #fff;
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 5px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    letter-spacing: 0.1px;
  }

  .partner-slide:hover .slide-tooltip {
    opacity: 1;
  }

  /* Prev / Next buttons */
  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 5;
    padding: 0;
  }

  .slider-prev { left: 6px; }
  .slider-next { right: 6px; }

  .partner-slider:hover .slider-btn {
    opacity: 1;
  }

  .slider-btn:hover {
    transform: translateY(-50%) scale(1.1);
    background: #fff;
  }

  /* Dots */
  .slider-dots {
    position: absolute;
    bottom: 6px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    z-index: 5;
  }

  .slider-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .slider-dot.active {
    background: #fff;
    transform: scale(1.3);
  }

  /* ── Copyright ── */
  .sidebar-copyright {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-copyright-divider {
    width: 100%;
    height: 1px;
    background: #f0f0f0;
  }

  .sidebar-copyright-text {
    font-size: 10px;
    color: #7a7a7a;
    line-height: 1.191;
    white-space: nowrap;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    /* Close button */
    .sidebar-close {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 16px;
      right: 16px;
      background: none;
      border: none;
      cursor: pointer;
      color: #111;
      padding: 4px;
      z-index: 10;
    }

    /* Sidebar: hidden by default, full-width overlay when open */
    .sidebar {
      width: 100%;
      transform: none;
      display: none;
    }

    .sidebar.open {
      display: block;
      box-shadow: none;
    }

    .sidebar-inner {
      position: relative;
      height: 100%;
      overflow-y: auto;
    }

    /* Push logo down to make room for close button */
    .sidebar-logo {
      margin-top: 8px;
    }
  }
</style>
