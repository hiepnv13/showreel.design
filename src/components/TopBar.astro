---
import { getTaxonomyLabel } from '../config/taxonomies';

interface Props {
  totalCount: number;
  allVideos: any[];
  h1Text?: string;
  h2Text?: string;
}

const {
  totalCount,
  allVideos = [],
  h1Text,
  h2Text,
} = Astro.props;

const currentPath = Astro.url.pathname;
const showBanner =
  currentPath === '/' ||
  currentPath.startsWith('/page/') ||
  currentPath.startsWith('/category/') ||
  currentPath.startsWith('/industry/') ||
  currentPath.startsWith('/style/') ||
  currentPath.startsWith('/sound/') ||
  currentPath.startsWith('/year/');

const h1 = h1Text ?? `Discover ${totalCount} Best Showreels`;
const h2 = h2Text ?? `Curated showreels from top studios and creators worldwide.`;

const industryMatch = currentPath.match(/^\/industry\/(.+)/);
const styleMatch    = currentPath.match(/^\/style\/(.+)/);
const soundMatch    = currentPath.match(/^\/sound\/(.+)/);
const activeIndustry = industryMatch?.[1] ?? '';
const activeStyle    = styleMatch?.[1]    ?? '';
const activeSound    = soundMatch?.[1]    ?? '';

const availableIndustries = [...new Set(allVideos.flatMap((v: any) => v.data.industries ?? []))];
const availableStyles     = [...new Set(allVideos.flatMap((v: any) => v.data.styles ?? []))];
const availableSounds     = [...new Set(allVideos.flatMap((v: any) => v.data.soundMusic ?? []))].filter(s => s !== 'no-sound');

const groups = [
  {
    key: 'industry', label: 'Industry', title: 'Made for...',
    options: availableIndustries, active: activeIndustry,
    getLabel: (v: string) => getTaxonomyLabel('industries', v),
    getUrl: (v: string) => `/industry/${v}`, clearUrl: '/',
  },
  {
    key: 'style', label: 'Style', title: 'Looks like...',
    options: availableStyles, active: activeStyle,
    getLabel: (v: string) => getTaxonomyLabel('styles', v),
    getUrl: (v: string) => `/style/${v}`, clearUrl: '/',
  },
  {
    key: 'sound', label: 'Sound', title: 'Sounds like...',
    options: availableSounds, active: activeSound,
    getLabel: (v: string) => getTaxonomyLabel('soundMusic', v),
    getUrl: (v: string) => `/sound/${v}`, clearUrl: '/',
  },
].filter(g => g.options.length > 0);

const hasActiveFilter = !!(activeIndustry || activeStyle || activeSound);

const bannerSlides = [
  {
    video: 'https://video.showreel.design/Banner/Lotie%20MCP.mp4',
    link:  'https://lottie.link/showreeldesign',
    logo:  '/uploads/lottiefiles-logo.png',
    title: 'Meet Lottie Creator: The AI-powered motion tool for designers.',
  },
  {
    video: 'https://video.showreel.design/Banner/Framer3.mp4',
    link:  'https://framer.link/srd',
    logo:  '/uploads/Framer.png',
    title: 'Framer — Build professional websites with AI.',
  },
];
---

<div class="topbar-wrap">

  <!-- Single heading block: H1+H2+Search+Filter | Banner -->
  <div class="topbar-block">

    <!-- Left: top = H1+H2+Search, bottom = filter -->
    <div class="topbar-left">

      <!-- Top group -->
      <div class="topbar-top">
        <h1 class="topbar-h1">{h1}</h1>
        <p class="topbar-h2">{h2}</p>

      </div>

      <!-- Bottom: filter groups — align bottom -->
      <div class="topbar-filters">
        {groups.map(group => (
          <div class="filter-group" data-group={group.key}>
            <button class={`filter-group-btn ${group.active ? 'active' : ''}`} data-group-btn={group.key}>
              <span class="filter-group-label">
                {group.active ? group.getLabel(group.active) : group.label}
              </span>
              <svg class="filter-group-caret" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="filter-group-panel" data-group-panel={group.key}>
              <p class="filter-group-title">{group.title}</p>
              {group.options.map(value => (
                <a
                  href={group.active === value ? group.clearUrl : group.getUrl(value)}
                  class={`filter-option ${group.active === value ? 'checked' : ''}`}
                >
                  <span class="filter-option-label">{group.getLabel(value)}</span>
                  <span class="filter-option-check">✓</span>
                </a>
              ))}
            </div>
          </div>
        ))}
        {hasActiveFilter && <a href="/" class="filter-clear">Clear</a>}
      </div>

    </div>

    <!-- Right: video banner slider -->
    {showBanner && (
      <div class="topbar-banner">
        <div class="banner-slider" id="banner-slider">

          <!-- Video track wrapper (overflow hidden here) -->
          <div class="banner-track-wrap">
            <div class="banner-track" id="banner-track">
              {bannerSlides.map((slide, i) => (
                <div class="banner-slide-video">
                  <a href={slide.link} target="_blank" rel="noopener noreferrer" class="banner-video-link">
                    <video
                      class="banner-video"
                      src={slide.video}
                      autoplay={i === 0}
                      muted
                      loop
                      playsinline
                      data-index={i}
                    ></video>
                  </a>

                  <button class="banner-btn banner-mute-btn" aria-label="Toggle mute">
                    <svg class="icon-muted" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                      <line x1="23" y1="9" x2="17" y2="15"/>
                      <line x1="17" y1="9" x2="23" y2="15"/>
                    </svg>
                    <svg class="icon-unmuted" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                      <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
                      <path d="M15.54 8.46a5 5 0 0 1 0 7.07"/>
                      <path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>
                    </svg>
                  </button>

                  <a href={slide.link} target="_blank" rel="noopener noreferrer" class="banner-btn banner-arrow-btn" aria-label="Open link">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M7 17L17 7M17 7H7M17 7v10"/>
                    </svg>
                  </a>
                </div>
              ))}
            </div>

            <!-- Prev / Next inside track-wrap -->
            <button class="banner-nav-btn banner-prev" id="banner-prev" aria-label="Previous">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <button class="banner-nav-btn banner-next" id="banner-next" aria-label="Next">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>

            <!-- Dots -->
            <div class="banner-dots" id="banner-dots">
              {bannerSlides.map((_, i) => (
                <button class={`banner-dot ${i === 0 ? 'active' : ''}`} data-index={i}></button>
              ))}
            </div>
          </div>

          <!-- Info sections (outside overflow-hidden) -->
          {bannerSlides.map((slide, i) => (
            <div class="banner-info" data-info-index={i} style={i === 0 ? 'display:flex' : 'display:none'}>
              <img src={slide.logo} alt={slide.title} class="banner-logo" loading="lazy" />
              <p class="banner-title">{slide.title}</p>
            </div>
          ))}

        </div>
      </div>
    )}

  </div>

</div>

<script is:inline>
(function() {
  // Dropdown toggle
  document.querySelectorAll('[data-group-btn]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var key = btn.getAttribute('data-group-btn');
      var panel = document.querySelector('[data-group-panel="' + key + '"]');
      var isOpen = panel && panel.classList.contains('open');
      document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
      document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
      if (!isOpen && panel) { panel.classList.add('open'); btn.classList.add('panel-open'); }
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
    document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
  });

  // Banner slider
  var track = document.getElementById('banner-track');
  var dots = document.querySelectorAll('#banner-dots .banner-dot');
  var prevBtn = document.getElementById('banner-prev');
  var nextBtn = document.getElementById('banner-next');
  var slides = document.querySelectorAll('.banner-slide-video');
  var total = slides.length;
  var current = 0;
  var isMuted = true;

  function goTo(index) {
    var prev = current;
    current = (index + total) % total;
    // Move track
    track.style.transform = 'translateX(-' + current + '00%)';
    // Update dots
    dots.forEach(function(d, i) { d.classList.toggle('active', i === current); });
    // Pause prev video, play current
    var prevVid = slides[prev] && slides[prev].querySelector('.banner-video');
    var currVid = slides[current] && slides[current].querySelector('.banner-video');
    if (prevVid) prevVid.pause();
    if (currVid) { currVid.muted = isMuted; currVid.play().catch(function(){}); }
    // Toggle info sections
    document.querySelectorAll('[data-info-index]').forEach(function(el) {
      var idx = Number(el.getAttribute('data-info-index'));
      el.style.display = idx === current ? 'flex' : 'none';
    });
  }

  function startAuto() {}
  function stopAuto() {}

  prevBtn && prevBtn.addEventListener('click', function(e) { e.preventDefault(); stopAuto(); goTo(current - 1); startAuto(); });
  nextBtn && nextBtn.addEventListener('click', function(e) { e.preventDefault(); stopAuto(); goTo(current + 1); startAuto(); });
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { stopAuto(); goTo(Number(dot.dataset.index)); startAuto(); });
  });

  // Mute toggle — affects all slides
  document.querySelectorAll('.banner-mute-btn').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      isMuted = !isMuted;
      document.querySelectorAll('.banner-video').forEach(function(v) { v.muted = isMuted; });
      document.querySelectorAll('.icon-muted').forEach(function(ic) { ic.style.display = isMuted ? '' : 'none'; });
      document.querySelectorAll('.icon-unmuted').forEach(function(ic) { ic.style.display = isMuted ? 'none' : ''; });
    });
  });

  // Pause on hover
  var sliderEl = document.getElementById('banner-slider');
  sliderEl && sliderEl.addEventListener('mouseenter', stopAuto);
  sliderEl && sliderEl.addEventListener('mouseleave', startAuto);

  startAuto();
})();
</script>

<style>
  .topbar-wrap { width: 100%; }

  /* ── Main block: 2 columns ── */
  .topbar-block {
    display: flex;
    gap: 32px;
    padding: 32px 32px 24px;
    align-items: stretch;
    border-bottom: 1px solid #f0f0f0;
  }

  /* Left: flex-col, space between top & filter */
  .topbar-left {
    flex: 2;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
  }

  .topbar-top {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .topbar-h1 {
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: #000;
    margin: 0;
  }

  .topbar-h2 {
    font-size: 13px;
    color: #000;
    opacity: 0.5;
    line-height: 1.191;
    margin: 0;
  }


  /* Filter — bottom of left column */
  .topbar-filters {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* Filter groups */
  .filter-group { position: relative; }

  .filter-group-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 10px;
    background: #f5f5f5;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    color: #4b5563;
    font-family: 'Aileron', sans-serif;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .filter-group-btn:hover, .filter-group-btn.panel-open { background: #e5e5e5; }
  .filter-group-btn.active { background: #111; color: #fff; }
  .filter-group-caret { flex-shrink: 0; transition: transform 0.2s; }
  .filter-group-btn.panel-open .filter-group-caret { transform: rotate(180deg); }
  .filter-group-btn.active .filter-group-caret path { stroke: #fff; }

  .filter-group-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 6px;
    min-width: 180px;
    z-index: 50;
    flex-direction: column;
    gap: 2px;
  }

  .filter-group-panel.open { display: flex; }

  .filter-group-title {
    font-size: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #bbb;
    padding: 4px 8px 6px;
    margin: 0 0 4px;
    border-bottom: 1px solid #f5f5f5;
  }

  .filter-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 8px;
    font-size: 12px;
    color: #555;
    text-decoration: none;
    border-radius: 5px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
    gap: 24px;
  }

  .filter-option:hover { background: #f5f5f5; color: #111; }
  .filter-option.checked { color: #111; font-weight: 500; background: #f9f9f9; }
  .filter-option-label { flex: 1; }
  .filter-option-check { font-size: 10px; color: #111; opacity: 0; flex-shrink: 0; }
  .filter-option.checked .filter-option-check { opacity: 1; }

  .filter-clear {
    font-size: 11px;
    color: #999;
    text-decoration: none;
    padding: 0 4px;
    transition: color 0.15s;
  }
  .filter-clear:hover { color: #333; }

  /* ── Banner slider ── */
  .topbar-banner {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .banner-slider {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  /* Overflow hidden only on the video track area */
  .banner-track-wrap {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
  }

  .banner-track {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .banner-slide-video {
    flex: 0 0 100%;
    position: relative;
    aspect-ratio: 16 / 9;
    background: #111;
  }

  .banner-video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #111;
  }

  /* Info sections */
  .banner-info { display: flex; }
  .banner-info-hidden { display: none; }

  .banner-video-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .banner-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay buttons (mute + arrow) */
  .banner-btn {
    position: absolute;
    bottom: 8px;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(90, 90, 90, 0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    box-shadow:
      0px -1px 0px 0px rgba(255,255,255,0.35),
      1px  0px 0px 0px rgba(255,255,255,0.15),
      -1px 0px 0px 0px rgba(255,255,255,0.15),
      0px  1px 0px 0px rgba(255,255,255,0.30),
      0px  1px 1px 0px rgba(0,0,0,0.20);
    transition: background 0.15s;
    z-index: 2;
  }

  .banner-btn:hover { background: rgba(90, 90, 90, 0.65); }
  .banner-mute-btn { left: 8px; }
  .banner-arrow-btn { right: 8px; opacity: 0; transition: opacity 0.2s, background 0.15s; }
  .banner-slide-video:hover .banner-arrow-btn { opacity: 1; }

  /* Prev / Next nav buttons */
  .banner-nav-btn {
    position: absolute;
    top: calc(50% - 16px); /* vertically center on video area */
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(4px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    z-index: 5;
    padding: 0;
  }

  .banner-prev { left: 6px; }
  .banner-next { right: 6px; }

  .banner-slider:hover .banner-nav-btn { opacity: 1; }
  .banner-nav-btn:hover { transform: translateY(-50%) scale(1.1); background: #fff; }

  /* Dots */
  .banner-dots {
    position: absolute;
    bottom: 20px; /* inside video area */
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    z-index: 5;
  }

  .banner-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }

  .banner-dot.active { background: #fff; transform: scale(1.3); }

  /* Info below video */
  .banner-info {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .banner-logo {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: #fff;
    border: 1px solid #eeeeee;
  }

  .banner-title {
    font-size: 13px;
    color: #1b1b1b;
    line-height: 1.3;
    margin: 0;
    flex: 1;
    min-width: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .topbar-block {
      flex-direction: column;
      padding: 20px 16px 16px;
      gap: 20px;
    }

    .topbar-h1 { font-size: 24px; }
    .topbar-search { width: 100%; }
    .topbar-banner { display: none; }
  }
</style>
