---
import { getTaxonomyLabel } from '../config/taxonomies';

interface Props {
  totalCount: number;
  category?: string;
  allVideos: any[];
}

const {
  totalCount,
  category = 'Motion Design',
  allVideos = [],
} = Astro.props;

const currentPath = Astro.url.pathname;

// SEO copy
const h1 = `Discover ${totalCount} Best ${category} Showreels`;
const h2 = `Curated ${category.toLowerCase()} reels from top studios and creators worldwide.`;

// Active filter detection from URL
const industryMatch = currentPath.match(/^\/industry\/(.+)/);
const styleMatch    = currentPath.match(/^\/style\/(.+)/);
const soundMatch    = currentPath.match(/^\/sound\/(.+)/);
const activeIndustry = industryMatch?.[1] ?? '';
const activeStyle    = styleMatch?.[1]    ?? '';
const activeSound    = soundMatch?.[1]    ?? '';

// Available options from current view's videos
const availableIndustries = [...new Set(allVideos.flatMap((v: any) => v.data.industries ?? []))];
const availableStyles     = [...new Set(allVideos.flatMap((v: any) => v.data.styles ?? []))];
const availableSounds     = [...new Set(allVideos.flatMap((v: any) => v.data.soundMusic ?? []))].filter(s => s !== 'no-sound');

const groups = [
  {
    key: 'industry', label: 'Industry', title: 'Made for...',
    options: availableIndustries,
    active: activeIndustry,
    getLabel: (v: string) => getTaxonomyLabel('industries', v),
    getUrl:   (v: string) => `/industry/${v}`,
    clearUrl: '/',
  },
  {
    key: 'style', label: 'Style', title: 'Looks like...',
    options: availableStyles,
    active: activeStyle,
    getLabel: (v: string) => getTaxonomyLabel('styles', v),
    getUrl:   (v: string) => `/style/${v}`,
    clearUrl: '/',
  },
  {
    key: 'sound', label: 'Sound', title: 'Sounds like...',
    options: availableSounds,
    active: activeSound,
    getLabel: (v: string) => getTaxonomyLabel('soundMusic', v),
    getUrl:   (v: string) => `/sound/${v}`,
    clearUrl: '/',
  },
].filter(g => g.options.length > 0);

const hasActiveFilter = !!(activeIndustry || activeStyle || activeSound);
---

<div class="topbar-wrap">

  <!-- H1 / H2 — static -->
  <div class="topbar-heading">
    <h1 class="topbar-h1">{h1}</h1>
    <p class="topbar-h2">{h2}</p>
  </div>

  <!-- Filter row — sticky -->
  <div class="topbar-filter">
    <div class="topbar-filter-left">

      {groups.map(group => (
        <div class="filter-group" data-group={group.key}>
          <button class={`filter-group-btn ${group.active ? 'active' : ''}`} data-group-btn={group.key}>
            <span class="filter-group-label">
              {group.active ? group.getLabel(group.active) : group.label}
            </span>
            <svg class="filter-group-caret" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="filter-group-panel" data-group-panel={group.key}>
            <p class="filter-group-title">{group.title}</p>
            {group.options.map(value => (
              <a
                href={group.active === value ? group.clearUrl : group.getUrl(value)}
                class={`filter-option ${group.active === value ? 'checked' : ''}`}
              >
                <span class="filter-option-label">{group.getLabel(value)}</span>
                <span class="filter-option-check">✓</span>
              </a>
            ))}
          </div>
        </div>
      ))}

      {hasActiveFilter && (
        <a href="/" class="filter-clear">Clear</a>
      )}
    </div>

    <!-- Search -->
    <form action="/search" method="get" class="topbar-search">
      <input type="text" name="q" placeholder="Search" class="topbar-search-input" autocomplete="off" />
      <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" class="topbar-search-icon">
        <path d="M229.66 218.34l-50.06-50.07a88.11 88.11 0 1 0-11.31 11.31l50.06 50.07a8 8 0 0 0 11.31-11.31zM40 112a72 72 0 1 1 72 72 72.08 72.08 0 0 1-72-72z"/>
      </svg>
    </form>
  </div>

</div>

<script is:inline>
(function() {
  // Dropdown toggle only — no JS filtering needed (URL-based)
  document.querySelectorAll('[data-group-btn]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var key = btn.getAttribute('data-group-btn');
      var panel = document.querySelector('[data-group-panel="' + key + '"]');
      var isOpen = panel && panel.classList.contains('open');
      document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
      document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
      if (!isOpen && panel) { panel.classList.add('open'); btn.classList.add('panel-open'); }
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
    document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
  });
})();
</script>

<style>
  .topbar-wrap { width: 100%; }

  .topbar-heading {
    padding: 32px 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .topbar-h1 {
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: #000;
    margin: 0;
  }

  .topbar-h2 {
    font-size: 13px;
    color: #000;
    opacity: 0.5;
    line-height: 1.191;
    margin: 0;
  }

  .topbar-filter {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 32px;
  }

  .topbar-filter-left {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
    min-width: 0;
  }

  /* Filter group */
  .filter-group { position: relative; }

  .filter-group-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 10px;          /* matches search box height */
    background: #f5f5f5;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    color: #4b5563;
    font-family: 'Aileron', sans-serif;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .filter-group-btn:hover,
  .filter-group-btn.panel-open { background: #e5e5e5; }

  .filter-group-btn.active {
    background: #111;
    color: #fff;
  }

  .filter-group-caret {
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .filter-group-btn.panel-open .filter-group-caret { transform: rotate(180deg); }
  .filter-group-btn.active .filter-group-caret path { stroke: #fff; }

  /* Dropdown panel */
  .filter-group-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 6px;
    min-width: 180px;
    z-index: 50;
    flex-direction: column;
    gap: 2px;
  }

  .filter-group-panel.open { display: flex; }

  .filter-group-title {
    font-size: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #bbb;
    padding: 4px 8px 6px;
    margin: 0;
    border-bottom: 1px solid #f5f5f5;
    margin-bottom: 4px;
  }

  .filter-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 8px;
    font-size: 12px;
    color: #555;
    text-decoration: none;
    cursor: pointer;
    border-radius: 5px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
    gap: 24px;
  }

  .filter-option:hover { background: #f5f5f5; color: #111; }

  .filter-option.checked {
    color: #111;
    font-weight: 500;
    background: #f9f9f9;
  }

  .filter-option-label { flex: 1; }

  .filter-option-check {
    font-size: 10px;
    color: #111;
    opacity: 0;
    flex-shrink: 0;
  }

  .filter-option.checked .filter-option-check { opacity: 1; }

  /* Clear link */
  .filter-clear {
    font-size: 11px;
    color: #999;
    text-decoration: none;
    padding: 0 4px;
    transition: color 0.15s;
  }

  .filter-clear:hover { color: #333; }

  /* Search — same height as filter buttons */
  .topbar-search {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f5f5f5;
    border-radius: 8px;
    padding: 8px 12px;
    width: 300px;
    flex-shrink: 0;
  }

  .topbar-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 13px;
    font-family: 'Aileron', sans-serif;
    color: #111;
    opacity: 0.5;
    min-width: 0;
  }

  .topbar-search-input::placeholder { color: #000; }
  .topbar-search-input:focus { opacity: 1; }
  .topbar-search-icon { color: #888; flex-shrink: 0; }

  @media (max-width: 768px) {
    .topbar-heading { padding: 20px 16px 16px; }
    .topbar-h1 { font-size: 24px; }
    .topbar-filter { padding: 8px 16px; top: 52px; }
    .topbar-search { display: none; }
  }
</style>
