---
import { getTaxonomyLabel } from '../config/taxonomies';

interface Props {
  totalCount: number;
  category?: string;
  allVideos: any[];
}

const {
  totalCount,
  category = 'Motion Design',
  allVideos = [],
} = Astro.props;

// SEO copy
const h1 = `Discover ${totalCount} Best ${category} Showreels`;
const h2 = `Curated ${category.toLowerCase()} reels from top studios and creators worldwide.`;

// Available taxonomy options in current view
const availableIndustries = [...new Set(allVideos.flatMap((v: any) => v.data.industries ?? []))];
const availableStyles     = [...new Set(allVideos.flatMap((v: any) => v.data.styles ?? []))];
const availableSounds     = [...new Set(allVideos.flatMap((v: any) => v.data.soundMusic ?? []))].filter(s => s !== 'no-sound');

const groups = [
  {
    key: 'industry',
    label: 'Industry',
    options: availableIndustries,
    getLabel: (v: string) => getTaxonomyLabel('industries', v),
  },
  {
    key: 'style',
    label: 'Style',
    options: availableStyles,
    getLabel: (v: string) => getTaxonomyLabel('styles', v),
  },
  {
    key: 'sound',
    label: 'Sound',
    options: availableSounds,
    getLabel: (v: string) => getTaxonomyLabel('soundMusic', v),
  },
].filter(g => g.options.length > 0);
---

<div class="topbar-wrap">

  <!-- H1 / H2 — static -->
  <div class="topbar-heading">
    <h1 class="topbar-h1">{h1}</h1>
    <p class="topbar-h2">{h2}</p>
  </div>

  <!-- Filter row — sticky -->
  <div class="topbar-filter">
    <div class="topbar-filter-left">

      {groups.map(group => (
        <div class="filter-group" data-group={group.key}>
          <button class="filter-group-btn" data-group-btn={group.key}>
            <span class="filter-group-label">{group.label}</span>
            <span class="filter-group-count" style="display:none"></span>
            <svg class="filter-group-caret" width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="filter-group-panel" data-group-panel={group.key}>
            {group.options.map(value => (
              <label class="filter-option" data-value={value} data-group={group.key}>
                <span class="filter-checkbox-box"></span>
                <span>{group.getLabel(value)}</span>
              </label>
            ))}
          </div>
        </div>
      ))}

      <button class="filter-clear" id="filter-clear" style="display:none">Clear</button>
      <span class="filter-result-count" id="filter-result-count"></span>
    </div>

    <!-- Search -->
    <form action="/search" method="get" class="topbar-search">
      <input type="text" name="q" placeholder="Search" class="topbar-search-input" autocomplete="off" />
      <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" class="topbar-search-icon">
        <path d="M229.66 218.34l-50.06-50.07a88.11 88.11 0 1 0-11.31 11.31l50.06 50.07a8 8 0 0 0 11.31-11.31zM40 112a72 72 0 1 1 72 72 72.08 72.08 0 0 1-72-72z"/>
      </svg>
    </form>
  </div>

</div>

<script is:inline>
(function() {
  // State: active filters per group
  var active = { industry: [], style: [], sound: [] };

  function getCards() {
    return document.querySelectorAll('[data-video-taxonomies]');
  }

  function filterCards() {
    var cards = getCards();
    var shown = 0;

    cards.forEach(function(card) {
      var tags = (card.getAttribute('data-video-taxonomies') || '').split(' ').filter(Boolean);
      var match = true;

      ['industry', 'style', 'sound'].forEach(function(group) {
        if (active[group].length === 0) return;
        var groupMatch = active[group].some(function(f) { return tags.indexOf(f) !== -1; });
        if (!groupMatch) match = false;
      });

      card.style.display = match ? '' : 'none';
      if (match) shown++;
    });

    // Update result count
    var hasFilters = Object.values(active).some(function(a) { return a.length > 0; });
    var countEl = document.getElementById('filter-result-count');
    var clearEl = document.getElementById('filter-clear');
    if (countEl) countEl.textContent = hasFilters ? shown + ' result' + (shown !== 1 ? 's' : '') : '';
    if (clearEl) clearEl.style.display = hasFilters ? '' : 'none';
  }

  function syncUI() {
    // Sync checkbox visuals + button state
    document.querySelectorAll('.filter-option').forEach(function(opt) {
      var group = opt.getAttribute('data-group');
      var value = opt.getAttribute('data-value');
      var isChecked = active[group] && active[group].indexOf(value) !== -1;
      var box = opt.querySelector('.filter-checkbox-box');
      if (box) box.textContent = isChecked ? '✓' : '';
      opt.classList.toggle('checked', isChecked);
    });

    // Sync button badge counts
    ['industry', 'style', 'sound'].forEach(function(group) {
      var btn = document.querySelector('[data-group-btn="' + group + '"]');
      if (!btn) return;
      var count = active[group].length;
      var countEl = btn.querySelector('.filter-group-count');
      if (countEl) {
        countEl.textContent = count > 0 ? count : '';
        countEl.style.display = count > 0 ? '' : 'none';
      }
      btn.classList.toggle('active', count > 0);
    });
  }

  // Dropdown toggle
  document.querySelectorAll('[data-group-btn]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var key = btn.getAttribute('data-group-btn');
      var panel = document.querySelector('[data-group-panel="' + key + '"]');
      var isOpen = panel && panel.classList.contains('open');
      document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
      document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
      if (!isOpen && panel) {
        panel.classList.add('open');
        btn.classList.add('panel-open');
      }
    });
  });

  document.addEventListener('click', function() {
    document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
    document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
  });

  // Option click
  document.querySelectorAll('.filter-option').forEach(function(opt) {
    opt.addEventListener('click', function(e) {
      e.stopPropagation();
      var group = opt.getAttribute('data-group');
      var value = opt.getAttribute('data-value');
      if (!group || !value) return;
      var idx = active[group].indexOf(value);
      if (idx === -1) {
        active[group].push(value);
      } else {
        active[group].splice(idx, 1);
      }
      syncUI();
      filterCards();
    });
  });

  // Clear all
  var clearBtn = document.getElementById('filter-clear');
  if (clearBtn) {
    clearBtn.addEventListener('click', function() {
      active = { industry: [], style: [], sound: [] };
      syncUI();
      filterCards();
    });
  }
})();
</script>

<style>
  .topbar-wrap { width: 100%; }

  /* Heading */
  .topbar-heading {
    padding: 32px 32px 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .topbar-h1 {
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: #000;
    margin: 0;
  }

  .topbar-h2 {
    font-size: 13px;
    color: #000;
    opacity: 0.5;
    line-height: 1.191;
    margin: 0;
  }

  /* Filter row */
  .topbar-filter {
    position: sticky;
    top: 0;
    z-index: 40;
    background: #fff;
    border-bottom: 1px solid #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 32px;
    min-height: 44px;
  }

  .topbar-filter-left {
    display: flex;
    align-items: center;
    gap: 6px;
    flex: 1;
    min-width: 0;
  }

  /* Filter group */
  .filter-group { position: relative; }

  .filter-group-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    height: 23px;
    padding: 0 6px;
    background: #f5f5f5;
    border: none;
    border-radius: 4px;
    font-size: 10px;
    color: #4b5563;
    font-family: 'Aileron', sans-serif;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .filter-group-btn:hover, .filter-group-btn.panel-open { background: #e5e5e5; }
  .filter-group-btn.active { background: #333; color: #fff; }

  .filter-group-count {
    background: rgba(255,255,255,0.25);
    border-radius: 3px;
    padding: 0 3px;
    font-size: 9px;
    line-height: 14px;
  }

  .filter-group-btn:not(.active) .filter-group-count { background: rgba(0,0,0,0.1); }

  .filter-group-caret {
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .filter-group-btn.panel-open .filter-group-caret { transform: rotate(180deg); }

  /* Dropdown */
  .filter-group-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 6px;
    min-width: 180px;
    z-index: 50;
    flex-direction: column;
    gap: 2px;
  }

  .filter-group-panel.open { display: flex; }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 8px;
    font-size: 12px;
    color: #333;
    cursor: pointer;
    border-radius: 5px;
    transition: background 0.1s;
    white-space: nowrap;
    user-select: none;
  }

  .filter-option:hover { background: #f5f5f5; }
  .filter-option.checked { color: #111; font-weight: 500; }

  .filter-checkbox-box {
    width: 14px;
    height: 14px;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    flex-shrink: 0;
    background: #fff;
  }

  .filter-option.checked .filter-checkbox-box {
    background: #111;
    border-color: #111;
    color: #fff;
  }

  .filter-clear {
    font-size: 10px;
    color: #999;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0 4px;
    font-family: 'Aileron', sans-serif;
    transition: color 0.15s;
  }

  .filter-clear:hover { color: #333; }

  .filter-result-count {
    font-size: 10px;
    color: #bbb;
    white-space: nowrap;
  }

  /* Search */
  .topbar-search {
    display: flex;
    align-items: center;
    gap: 8px;
    background: #f5f5f5;
    border-radius: 8px;
    padding: 8px 12px;
    width: 300px;
    flex-shrink: 0;
  }

  .topbar-search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 13px;
    font-family: 'Aileron', sans-serif;
    color: #111;
    opacity: 0.5;
    min-width: 0;
  }

  .topbar-search-input::placeholder { color: #000; }
  .topbar-search-input:focus { opacity: 1; }
  .topbar-search-icon { color: #888; flex-shrink: 0; }

  /* Mobile */
  @media (max-width: 768px) {
    .topbar-heading { padding: 20px 16px 16px; }
    .topbar-h1 { font-size: 24px; }
    .topbar-filter { padding: 8px 16px; top: 52px; }
    .topbar-search { display: none; }
  }
</style>
