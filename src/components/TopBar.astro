---
import { getTaxonomyLabel } from '../config/taxonomies';

interface Props {
  totalCount: number;
  allVideos: any[];
  h1Text?: string;
  h2Text?: string;
}

const {
  totalCount,
  allVideos = [],
  h1Text,
  h2Text,
} = Astro.props;

const currentPath = Astro.url.pathname;
const showBanner =
  currentPath === '/' ||
  currentPath.startsWith('/page/') ||
  currentPath.startsWith('/category/') ||
  currentPath.startsWith('/industry/') ||
  currentPath.startsWith('/style/') ||
  currentPath.startsWith('/sound/') ||
  currentPath.startsWith('/year/');

const h1 = h1Text ?? `Discover ${totalCount} Best Showreels`;
const h2 = h2Text ?? `Curated showreels from top studios and creators worldwide.`;

const industryMatch = currentPath.match(/^\/industry\/(.+)/);
const styleMatch    = currentPath.match(/^\/style\/(.+)/);
const soundMatch    = currentPath.match(/^\/sound\/(.+)/);
const activeIndustry = industryMatch?.[1] ?? '';
const activeStyle    = styleMatch?.[1]    ?? '';
const activeSound    = soundMatch?.[1]    ?? '';

const availableIndustries = [...new Set(allVideos.flatMap((v: any) => v.data.industries ?? []))];
const availableStyles     = [...new Set(allVideos.flatMap((v: any) => v.data.styles ?? []))];
const availableSounds     = [...new Set(allVideos.flatMap((v: any) => v.data.soundMusic ?? []))].filter(s => s !== 'no-sound');

const groups = [
  {
    key: 'industry', label: 'Industry', title: 'Made for...',
    options: availableIndustries, active: activeIndustry,
    getLabel: (v: string) => getTaxonomyLabel('industries', v),
    getUrl: (v: string) => `/industry/${v}`, clearUrl: '/',
  },
  {
    key: 'style', label: 'Style', title: 'Looks like...',
    options: availableStyles, active: activeStyle,
    getLabel: (v: string) => getTaxonomyLabel('styles', v),
    getUrl: (v: string) => `/style/${v}`, clearUrl: '/',
  },
  {
    key: 'sound', label: 'Sound', title: 'Sounds like...',
    options: availableSounds, active: activeSound,
    getLabel: (v: string) => getTaxonomyLabel('soundMusic', v),
    getUrl: (v: string) => `/sound/${v}`, clearUrl: '/',
  },
].filter(g => g.options.length > 0);

const hasActiveFilter = !!(activeIndustry || activeStyle || activeSound);

const BANNER_VIDEO = 'https://video.showreel.design/Banner/Lotie%20MCP.mp4';
const BANNER_LINK  = 'https://lottie.link/showreeldesign';
---

<div class="topbar-wrap">

  <!-- Single heading block: H1+H2+Search+Filter | Banner -->
  <div class="topbar-block">

    <!-- Left: top = H1+H2+Search, bottom = filter -->
    <div class="topbar-left">

      <!-- Top group -->
      <div class="topbar-top">
        <h1 class="topbar-h1">{h1}</h1>
        <p class="topbar-h2">{h2}</p>

      </div>

      <!-- Bottom: filter groups — align bottom -->
      <div class="topbar-filters">
        {groups.map(group => (
          <div class="filter-group" data-group={group.key}>
            <button class={`filter-group-btn ${group.active ? 'active' : ''}`} data-group-btn={group.key}>
              <span class="filter-group-label">
                {group.active ? group.getLabel(group.active) : group.label}
              </span>
              <svg class="filter-group-caret" width="12" height="12" viewBox="0 0 12 12" fill="none">
                <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="filter-group-panel" data-group-panel={group.key}>
              <p class="filter-group-title">{group.title}</p>
              {group.options.map(value => (
                <a
                  href={group.active === value ? group.clearUrl : group.getUrl(value)}
                  class={`filter-option ${group.active === value ? 'checked' : ''}`}
                >
                  <span class="filter-option-label">{group.getLabel(value)}</span>
                  <span class="filter-option-check">✓</span>
                </a>
              ))}
            </div>
          </div>
        ))}
        {hasActiveFilter && <a href="/" class="filter-clear">Clear</a>}
      </div>

    </div>

    <!-- Right: video banner (homepage only) -->
    {showBanner && (
      <div class="topbar-banner">
        <div class="banner-video-wrap group" id="banner-wrap">
          <!-- Video click → open link -->
          <a href={BANNER_LINK} target="_blank" rel="noopener noreferrer" class="banner-video-link" id="banner-link">
            <video
              id="banner-video"
              class="banner-video"
              src={BANNER_VIDEO}
              autoplay
              muted
              loop
              playsinline
            ></video>
          </a>

          <!-- Mute button (always visible) -->
          <button class="banner-btn banner-mute-btn" id="banner-mute-btn" aria-label="Toggle mute">
            <svg id="banner-icon-muted" width="14" height="14" viewBox="0 0 256 256" fill="currentColor">
              <path d="M53.92 34.62a8 8 0 1 0-11.84 10.76L72 80.14V104H48a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h19.59L72 221.48V232a8 8 0 0 0 13.34 6l44.06-40.52 30.92 33.78a8 8 0 1 0 11.84-10.76ZM88 211.48l-16-17.47V152H48v-32h24v-28.66Zm99.25-42.77a48 48 0 0 0 0-81.42 8 8 0 0 0-8 13.86 32 32 0 0 1 0 53.7 8 8 0 0 0 8 13.86ZM240 128a79.9 79.9 0 0 1-37.65 68.12 8 8 0 0 1-8-13.86 64 64 0 0 0 0-108.52 8 8 0 1 1 8-13.86A79.9 79.9 0 0 1 240 128ZM80 88.14 152 24a8 8 0 0 1 8 .38V112l-80-23.86Z"/>
            </svg>
            <svg id="banner-icon-unmuted" width="14" height="14" viewBox="0 0 256 256" fill="currentColor" style="display:none">
              <path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H48A16 16 0 0 0 32 96v64a16 16 0 0 0 16 16h29.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19ZM144 207.64l-56-43.55A8 8 0 0 0 83 160H48V96h35a8 8 0 0 0 5-1.68l56-43.55Zm50.41-107.95a8 8 0 0 1 0 11.32 48.15 48.15 0 0 1 0 33.94 8 8 0 0 1-11.32-11.32 32.09 32.09 0 0 0 0-22.62 8 8 0 0 1 11.32-11.32Z"/>
            </svg>
          </button>

          <!-- Arrow button — show on hover -->
          <a href={BANNER_LINK} target="_blank" rel="noopener noreferrer" class="banner-btn banner-arrow-btn" aria-label="Open link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        </div>

        <p class="banner-title">Meet Lottie Creator: The AI-powered motion tool for designers.</p>
      </div>
    )}

  </div>

</div>

<script is:inline>
(function() {
  // Dropdown toggle
  document.querySelectorAll('[data-group-btn]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var key = btn.getAttribute('data-group-btn');
      var panel = document.querySelector('[data-group-panel="' + key + '"]');
      var isOpen = panel && panel.classList.contains('open');
      document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
      document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
      if (!isOpen && panel) { panel.classList.add('open'); btn.classList.add('panel-open'); }
    });
  });
  document.addEventListener('click', function() {
    document.querySelectorAll('[data-group-panel]').forEach(function(p) { p.classList.remove('open'); });
    document.querySelectorAll('[data-group-btn]').forEach(function(b) { b.classList.remove('panel-open'); });
  });

  // Mute toggle
  var vid = document.getElementById('banner-video');
  var muteBtn = document.getElementById('banner-mute-btn');
  var iconMuted = document.getElementById('banner-icon-muted');
  var iconUnmuted = document.getElementById('banner-icon-unmuted');

  if (muteBtn && vid) {
    muteBtn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      vid.muted = !vid.muted;
      iconMuted.style.display = vid.muted ? '' : 'none';
      iconUnmuted.style.display = vid.muted ? 'none' : '';
    });
  }
})();
</script>

<style>
  .topbar-wrap { width: 100%; }

  /* ── Main block: 2 columns ── */
  .topbar-block {
    display: flex;
    gap: 32px;             /* matches grid gap-8 */
    padding: 32px 32px 24px;
    align-items: stretch;
  }

  /* Left: flex-col, space between top & filter */
  .topbar-left {
    flex: 2;
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 24px;
  }

  .topbar-top {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .topbar-h1 {
    font-size: 40px;
    font-weight: 400;
    letter-spacing: -0.5px;
    line-height: 1.1;
    color: #000;
    margin: 0;
  }

  .topbar-h2 {
    font-size: 13px;
    color: #000;
    opacity: 0.5;
    line-height: 1.191;
    margin: 0;
  }


  /* Filter — bottom of left column */
  .topbar-filters {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* Filter groups */
  .filter-group { position: relative; }

  .filter-group-btn {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 10px;
    background: #f5f5f5;
    border: none;
    border-radius: 8px;
    font-size: 12px;
    color: #4b5563;
    font-family: 'Aileron', sans-serif;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    white-space: nowrap;
  }

  .filter-group-btn:hover, .filter-group-btn.panel-open { background: #e5e5e5; }
  .filter-group-btn.active { background: #111; color: #fff; }
  .filter-group-caret { flex-shrink: 0; transition: transform 0.2s; }
  .filter-group-btn.panel-open .filter-group-caret { transform: rotate(180deg); }
  .filter-group-btn.active .filter-group-caret path { stroke: #fff; }

  .filter-group-panel {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    background: #fff;
    border: 1px solid #f0f0f0;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 6px;
    min-width: 180px;
    z-index: 50;
    flex-direction: column;
    gap: 2px;
  }

  .filter-group-panel.open { display: flex; }

  .filter-group-title {
    font-size: 10px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: #bbb;
    padding: 4px 8px 6px;
    margin: 0 0 4px;
    border-bottom: 1px solid #f5f5f5;
  }

  .filter-option {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 7px 8px;
    font-size: 12px;
    color: #555;
    text-decoration: none;
    border-radius: 5px;
    transition: background 0.1s, color 0.1s;
    white-space: nowrap;
    gap: 24px;
  }

  .filter-option:hover { background: #f5f5f5; color: #111; }
  .filter-option.checked { color: #111; font-weight: 500; background: #f9f9f9; }
  .filter-option-label { flex: 1; }
  .filter-option-check { font-size: 10px; color: #111; opacity: 0; flex-shrink: 0; }
  .filter-option.checked .filter-option-check { opacity: 1; }

  .filter-clear {
    font-size: 11px;
    color: #999;
    text-decoration: none;
    padding: 0 4px;
    transition: color 0.15s;
  }
  .filter-clear:hover { color: #333; }

  /* ── Banner (right column) — flex: 1 matches 1/3 of grid ── */
  .topbar-banner {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .banner-video-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #111;
  }

  .banner-video-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .banner-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Shared button style */
  .banner-btn {
    position: absolute;
    bottom: 8px;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(90, 90, 90, 0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    text-decoration: none;
    box-shadow:
      0px -1px 0px 0px rgba(255,255,255,0.35),
      1px  0px 0px 0px rgba(255,255,255,0.15),
      -1px 0px 0px 0px rgba(255,255,255,0.15),
      0px  1px 0px 0px rgba(255,255,255,0.30),
      0px  1px 1px 0px rgba(0,0,0,0.20);
    transition: background 0.15s;
    z-index: 2;
  }

  .banner-btn:hover { background: rgba(90, 90, 90, 0.65); }

  .banner-mute-btn { left: 8px; }

  /* Arrow button — right side, hidden by default, show on hover */
  .banner-arrow-btn {
    right: 8px;
    opacity: 0;
    transition: opacity 0.2s, background 0.15s;
  }

  .banner-video-wrap:hover .banner-arrow-btn { opacity: 1; }

  .banner-title {
    font-size: 13px;
    color: #555;
    line-height: 1.4;
    margin: 0;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .topbar-block {
      flex-direction: column;
      padding: 20px 16px 16px;
      gap: 20px;
    }

    .topbar-h1 { font-size: 24px; }
    .topbar-search { width: 100%; }
    .topbar-banner { display: none; }
  }
</style>
