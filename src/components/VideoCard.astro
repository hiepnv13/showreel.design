---
import { getTaxonomyLabel } from '../config/taxonomies';

export interface Props {
  title: string;
  author: string;
  authorAvatar?: string;
  thumbnail: string;
  videoUrl?: string;
  slug?: string;
  industries?: string[];
  styles?: string[];
  soundMusic?: string[];
}

const { title, author, authorAvatar, thumbnail, videoUrl, slug, industries = [], styles = [], soundMusic = [] } = Astro.props;

const taxonomyTags = [...industries, ...styles, ...soundMusic].join(' ');

const initials = (author ?? '')
  .split(' ')
  .slice(0, 2)
  .map((w: string) => w[0]?.toUpperCase() ?? '')
  .join('');

// 1 chip per taxonomy group (skip if empty or no-sound)
const chips = [
  industries[0]  ? getTaxonomyLabel('industries', industries[0])  : null,
  styles[0]      ? getTaxonomyLabel('styles', styles[0])          : null,
  soundMusic[0] && soundMusic[0] !== 'no-sound'
    ? getTaxonomyLabel('soundMusic', soundMusic[0]) : null,
].filter(Boolean) as string[];
---

<a href={slug ? `/videos/${slug}` : '#'} class="video-card group cursor-pointer block" data-video-url={videoUrl} data-video-taxonomies={taxonomyTags}>

  <!-- Thumbnail frame: 16:9, no bg, no padding -->
  <div class="card-frame">
    {videoUrl ? (
      <video
        class="video-element w-full h-full object-cover opacity-0 transition-opacity duration-500"
        muted
        loop
        playsinline
        preload="none"
        data-src={videoUrl}
      >
        <source data-src={videoUrl} type="video/mp4" />
      </video>
    ) : (
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    )}

    <!-- Taxonomy chips — appear on hover, bottom-left of thumbnail -->
    {chips.length > 0 && (
      <div class="card-chips">
        {chips.map(chip => (
          <span class="card-chip">{chip}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Card info: logo + video title -->
  <div class="card-info">
    {authorAvatar ? (
      <img class="card-avatar" src={authorAvatar} alt={author} loading="lazy" />
    ) : (
      <div class="card-avatar card-avatar-initials">{initials}</div>
    )}
    <p class="card-title">{title}</p>
  </div>

</a>

<script>
  // @ts-nocheck
  document.addEventListener('DOMContentLoaded', function() {
    const CONFIG = {
      rootMargin: '50px',
      threshold: 0.1,
      maxConcurrentVideos: 4,
      playThreshold: 0.5
    };

    let currentlyPlayingVideos = new Set();
    let loadedVideos = new WeakSet();

    const loadObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) loadVideo(entry.target);
      });
    }, { rootMargin: CONFIG.rootMargin, threshold: CONFIG.threshold });

    const playObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target;
        const video = card.querySelector('.video-element');
        if (!video || !loadedVideos.has(video)) return;
        if (entry.isIntersecting && entry.intersectionRatio >= CONFIG.playThreshold) {
          playVideo(video, card);
        } else {
          pauseVideoElement(video);
        }
      });
    }, { threshold: CONFIG.playThreshold });

    function loadVideo(card) {
      const video = card.querySelector('.video-element');
      if (!video || loadedVideos.has(video)) return;

      const dataSrc = video.getAttribute('data-src');
      if (dataSrc) {
        const source = video.querySelector('source');
        if (source) source.src = dataSrc;
        video.src = dataSrc;
      }

      video.addEventListener('canplay', () => {
        loadedVideos.add(video);
        video.style.opacity = '1';
        card.querySelector('.card-frame')?.classList.add('card-loaded');
        playObserver.observe(card);
      });

      video.addEventListener('error', () => {
        console.warn('Video failed to load:', dataSrc);
      });

      video.load();
    }

    function playVideo(video, card) {
      if (currentlyPlayingVideos.size >= CONFIG.maxConcurrentVideos) {
        const oldest = currentlyPlayingVideos.values().next().value;
        if (oldest && oldest !== video) pauseVideoElement(oldest);
      }
      video.currentTime = 0;
      video.play().then(() => {
        currentlyPlayingVideos.add(video);
      }).catch(() => {});
    }

    function pauseVideoElement(video) {
      video.pause();
      currentlyPlayingVideos.delete(video);
    }

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    document.querySelectorAll('.video-card').forEach(card => {
      loadObserver.observe(card);
    });

    window.addEventListener('beforeunload', () => {
      currentlyPlayingVideos.forEach(v => v.pause());
    });

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) currentlyPlayingVideos.forEach(v => v.pause());
    });
  });
</script>

<style>
  /* Frame: 16:9, no padding, no background */
  .card-frame {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    background: #d0d0d0;
  }

  /* Shimmer loading state */
  .card-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.45) 50%, transparent 100%);
    background-size: 200% 100%;
    animation: card-shimmer 1.4s infinite;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .card-frame.card-loaded::after {
    opacity: 0;
    animation: none;
  }

  @keyframes card-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* Taxonomy chips — absolute in frame, show on hover */
  .card-chips {
    position: absolute;
    bottom: 8px;
    left: 8px;
    display: flex;
    gap: 6px;
    z-index: 2;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .group:hover .card-chips {
    opacity: 1;
  }

  .card-chip {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 0 6.5px;
    border-radius: 8px;
    background: rgba(90, 90, 90, 0.4);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    box-shadow:
      0px -1px 0px 0px rgba(255,255,255,0.35),
      1px  0px 0px 0px rgba(255,255,255,0.15),
      -1px 0px 0px 0px rgba(255,255,255,0.15),
      0px  1px 0px 0px rgba(255,255,255,0.30),
      0px  1px 1px 0px rgba(0,0,0,0.20);
    color: #fff;
    font-size: 10px;
    letter-spacing: -0.08px;
    white-space: nowrap;
    line-height: 13px;
  }

  /* Card info below frame */
  .card-info {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 0 12px;
  }

  .card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
    background: #fff;
    border: 1px solid #eeeeee;
  }

  .card-avatar-initials {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: #2f2f2f;
    color: #ffffff;
    font-size: 12px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-title {
    font-size: 13px;
    color: #000;
    line-height: 1.191;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>
