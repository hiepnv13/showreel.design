---
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-white border-t border-gray-100 mt-auto">
  <!-- Main Footer Content -->
  <div class="px-6 sm:px-8 py-12 sm:py-16">
    <div class="flex flex-col sm:flex-row justify-between gap-10 sm:gap-12">

      <!-- Logo + Newsletter -->
      <div class="flex flex-col gap-4 w-full sm:w-[500px] flex-shrink-0">
        <a href="/" class="text-[22px] font-medium tracking-[0px] text-[#1a1a1a] hover:opacity-70 transition-opacity">
          SR.D
        </a>
        <div class="klaviyo-form-SffEDu"></div>
      </div>

      <!-- Links Columns -->
      <div class="flex flex-wrap gap-10 sm:gap-20">

        <!-- About -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">About</p>
          <a href="/about" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">About us</a>
          <a href="/privacy" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Privacy Policy</a>
        </div>

        <!-- Shop -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">Partner</p>
          <div class="flex flex-col gap-2">
            <a href="https://framer.link/srd" target="_blank" rel="noopener noreferrer" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Framer Templates</a>
            <a href="https://www.lapa.ninja?ref=showreel.design" target="_blank" rel="noopener noreferrer" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Lapa.ninja</a>
            <a href="https://www.landing.love?ref=showreel.design" target="_blank" rel="noopener noreferrer" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Landing.love</a>
            <a href="https://mobbin.com/?via=showreeldesign" target="_blank" rel="noopener noreferrer" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Mobbin — UI & UX Library</a>

            
          </div>
        </div>

        

        <!-- Social -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">Social</p>
          <div class="flex flex-col gap-2">
            <a href="https://x.com/showreeldesign" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Twitter (X)</a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="px-6 sm:px-8 py-4 border-t border-gray-100">
    <p class="text-[11px] text-gray-400">All showreel © of their respective owners</p>
  </div>

</footer>
