---
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-white border-t border-gray-100 mt-auto">
  <!-- Main Footer Content -->
  <div class="px-8 py-16">
    <div class="flex justify-between gap-12">

      <!-- Logo -->
      <div class="flex-shrink-0">
        <a href="/" class="text-[22px] font-medium tracking-[0px] text-[#1a1a1a] hover:opacity-70 transition-opacity">
          Showreel.design
        </a>
      </div>

      <!-- Links Columns -->
      <div class="flex gap-20">

        <!-- About -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">About</p>
          <a href="/about" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">About us</a>
        </div>

        <!-- Shop -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">Partner</p>
          <div class="flex flex-col gap-2">
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Framer Templates</a>
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Motion Templates</a>
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Bundles</a>
          </div>
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">Info</p>
          <div class="flex flex-col gap-2">
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Affiliates</a>
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">FAQ's</a>
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Visual Assets</a>
          </div>
        </div>

        <!-- Social -->
        <div class="flex flex-col gap-3">
          <p class="text-[10px] tracking-[1.5px] text-gray-400 uppercase font-medium">Social</p>
          <div class="flex flex-col gap-2">
            
            <a href="#" class="text-[13px] text-gray-600 hover:text-[#1a1a1a] transition-colors">Twitter (X)</a>
            
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
 
</footer>
