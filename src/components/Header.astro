---
// Header component matching Figma design
import { getAllCategories, generateSlug } from "../utils/videoUtils";

// Props for showing video counts or breadcrumb
interface Props {
  showingCount?: number;
  totalCount?: number;
  breadcrumb?: Array<{ label: string; href: string }>;
  searchQuery?: string;
}

const { showingCount, totalCount, breadcrumb, searchQuery } = Astro.props;

// Get current path to highlight active category
const currentPath = Astro.url.pathname;

// Get all categories dynamically
const allCategories = await getAllCategories();

// Build category buttons data
const categoryButtons = [
  { label: 'ALL', slug: '/', active: currentPath === '/' || currentPath.startsWith('/page/') }
];

// Add dynamic categories
for (const category of allCategories) {
  const slug = generateSlug(category);
  const isActive = currentPath.includes(`/category/${slug}`);
  categoryButtons.push({
    label: category,
    slug: `/category/${slug}`,
    active: isActive
  });
}
---

<header class="w-full bg-white sticky top-0 z-50 px-4 sm:px-8 pt-4 sm:pt-8 pb-3 sm:pb-4 flex flex-col gap-3 sm:gap-6">
  <!-- Top Row: Logo, Filters (desktop), Search -->
  <div class="flex items-center justify-between w-full">
    <!-- Logo -->
    <div class="pr-4 sm:pr-12 flex-shrink-0">
      <a href="/" class="text-[24px] sm:text-[30px] font-medium tracking-[0px] text-[#1a1a1a] hover:opacity-70 transition-opacity whitespace-nowrap">
        SR.D
      </a>
    </div>

    <!-- Category Filter Buttons — desktop only (center) -->
    <div class="hidden sm:flex items-center gap-2 flex-1 justify-center">
      {categoryButtons.map((cat) => (
        <a
          href={cat.slug}
          class={`filter-btn ${cat.active ? 'active' : ''}`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    <!-- Right controls: Search -->
    <div class="flex items-center gap-2 sm:gap-0 flex-shrink-0">
      <!-- Search Bar -->
      <div class="pl-2 sm:pl-4 flex-shrink-0">
        <form action="/search" method="get" class="border-b border-gray-200 pb-2 flex items-center gap-2 sm:gap-4">
          <input
            type="text"
            name="q"
            id="search-input"
            placeholder="Search"
            class="w-[100px] sm:w-[180px] bg-transparent border-none outline-none text-[13px] sm:text-[14px] placeholder-gray-500"
            autocomplete="off"
          />
          <button type="submit" class="text-gray-400 hover:text-gray-600 transition-colors flex-shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </div>

  <!-- Category Filter Buttons — mobile only (scrollable row) -->
  <div class="flex sm:hidden items-center gap-2 overflow-x-auto pb-1 -mx-4 px-4" style="scrollbar-width:none;-ms-overflow-style:none;">
    {categoryButtons.map((cat) => (
      <a
        href={cat.slug}
        class={`filter-btn flex-shrink-0 ${cat.active ? 'active' : ''}`}
      >
        {cat.label}
      </a>
    ))}
  </div>

  <!-- Results Counter / Breadcrumb -->
  <div class="w-full flex items-center">
    {breadcrumb ? (
      <!-- Breadcrumb Navigation -->
      <nav class="text-[10px] tracking-[1.5px] text-gray-500 font-medium flex items-center gap-1 uppercase">
        {breadcrumb.map((item, index) => (
          <>
            {item.href ? (
              <a href={item.href} class="hover:text-gray-700 transition-colors">{item.label}</a>
            ) : (
              <span class="text-gray-400">{item.label}</span>
            )}
            {index < breadcrumb.length - 1 && (
              <i class="fa-solid fa-caret-right text-[8px] mx-0.5 text-gray-400"></i>
            )}
          </>
        ))}
      </nav>
    ) : (
      <!-- Results Counter -->
      <span class="text-[10px] tracking-[1.5px] text-gray-500 font-medium flex items-center gap-1 uppercase" id="results-counter">
        Showing <span id="showing-count">{showingCount || 0}</span> <i class="fa-solid fa-caret-right text-[8px] mx-0.5 text-gray-400"></i> of <span id="total-count">{totalCount?.toLocaleString() || 0}</span>{searchQuery && <span class="normal-case text-gray-400 tracking-normal"> for "{searchQuery}"</span>}
      </span>
    )}
  </div>
</header>

<script>
  // Focus search input on Cmd+K / Ctrl+K
  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('search-input')?.focus();
    }
  });
</script>
