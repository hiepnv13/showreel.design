---
// Header component matching Figma design
import { getAllCategories, generateSlug } from "../utils/videoUtils";

// Props for showing video counts or breadcrumb
interface Props {
  showingCount?: number;  // Number of videos showing on current page
  totalCount?: number;    // Total number of videos in collection/category
  breadcrumb?: Array<{ label: string; href: string }>;  // Breadcrumb navigation for detail pages
}

const { showingCount, totalCount, breadcrumb } = Astro.props;

// Get current path to highlight active category
const currentPath = Astro.url.pathname;

// Get all categories dynamically
const allCategories = await getAllCategories();

// Build category buttons data
const categoryButtons = [
  { label: 'ALL', slug: '/', active: currentPath === '/' || currentPath.startsWith('/page/') }
];

// Add dynamic categories
for (const category of allCategories) {
  const slug = generateSlug(category);
  const isActive = currentPath.includes(`/category/${slug}`);
  categoryButtons.push({
    label: category,
    slug: `/category/${slug}`,
    active: isActive
  });
}
---

<header class="w-full bg-white sticky top-0 z-50 px-8 pt-8 pb-4 flex flex-col gap-6">
  <!-- Top Row: Logo, Filters, Search -->
  <div class="flex items-center justify-between w-full">
    <!-- Logo -->
    <div class="pr-12 flex-shrink-0">
      <a href="/" class="text-[30px] font-medium tracking-[0px] text-[#1a1a1a] hover:opacity-70 transition-opacity whitespace-nowrap">
        SR.D
      </a>
    </div>

    <!-- Category Filter Buttons -->
    <div class="flex items-center gap-2">
      {categoryButtons.map((cat) => (
        <a
          href={cat.slug}
          class={`filter-btn ${cat.active ? 'active' : ''}`}
        >
          {cat.label}
        </a>
      ))}
    </div>

    <!-- Dark Mode Toggle -->
    <button id="dark-toggle" class="dark-toggle" title="Toggle dark mode" aria-label="Toggle dark mode">
      <svg id="icon-moon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
      <svg id="icon-sun" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="5" stroke-width="1.5"/><path stroke-linecap="round" stroke-width="1.5" d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
      </svg>
    </button>

    <!-- Search Bar -->
    <div class="pl-4 flex-shrink-0" id="search-container">
      <form action="/search" method="get" class="border-b border-gray-200 pb-2 flex items-center gap-4">
        <input
          type="text"
          name="q"
          id="search-input"
          placeholder="Search showreel"
          class="w-[180px] bg-transparent border-none outline-none text-[14px] placeholder-gray-500"
          autocomplete="off"
        />
        <div class="bg-[#f0f0f0] px-2 py-1 rounded text-[12px] text-gray-500 border border-transparent">
          ENTER
        </div>
      </form>

      <!-- Search Suggestions Dropdown -->
      <div id="search-suggestions" class="absolute top-full left-0 right-0 bg-white border border-gray-200 rounded-lg shadow-lg mt-1 max-h-96 overflow-y-auto z-50 hidden">
        <div id="suggestions-content" class="py-2">
          <!-- Suggestions will be populated by JavaScript -->
        </div>
      </div>
    </div>
  </div>

  <!-- Results Counter / Breadcrumb -->
  <div class="w-full flex items-center">
    {breadcrumb ? (
      <!-- Breadcrumb Navigation -->
      <nav class="text-[10px] tracking-[1.5px] text-gray-500 font-medium flex items-center gap-1 uppercase">
        {breadcrumb.map((item, index) => (
          <>
            {item.href ? (
              <a href={item.href} class="hover:text-gray-700 transition-colors">{item.label}</a>
            ) : (
              <span class="text-gray-400">{item.label}</span>
            )}
            {index < breadcrumb.length - 1 && (
              <i class="fa-solid fa-caret-right text-[8px] mx-0.5 text-gray-400"></i>
            )}
          </>
        ))}
      </nav>
    ) : (
      <!-- Results Counter -->
      <span class="text-[10px] tracking-[1.5px] text-gray-500 font-medium flex items-center gap-1 uppercase" id="results-counter">
        Showing <span id="showing-count">{showingCount || 0}</span> <i class="fa-solid fa-caret-right text-[8px] mx-0.5 text-gray-400"></i> of <span id="total-count">{totalCount?.toLocaleString() || 0}</span>
      </span>
    )}
  </div>
</header>

<style>
  .dark-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    background: transparent;
    border: 1px solid #e5e7eb;
    border-radius: 2px;
    color: #9ca3af;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    flex-shrink: 0;
  }
  .dark-toggle:hover {
    color: #1a1a1a;
    border-color: #1a1a1a;
  }
  :global(html.dark) .dark-toggle {
    border-color: #2a2a2a;
    color: #666;
  }
  :global(html.dark) .dark-toggle:hover {
    color: #e0e0e0;
    border-color: #e0e0e0;
  }

  /* Search suggestions styling */
  #search-suggestions {
    z-index: 9999;
  }

  .suggestion-item:hover {
    background-color: #f9fafb;
  }

  .suggestion-item.bg-gray-100 {
    background-color: #f3f4f6;
  }

  /* Ensure search container has proper stacking context */
  #search-container {
    position: relative;
    z-index: 100;
  }
</style>

<script>
  import '../scripts/searchHandler.js';

  const toggle = document.getElementById('dark-toggle');
  const moon = document.getElementById('icon-moon');
  const sun = document.getElementById('icon-sun');
  const html = document.documentElement;

  function applyIcon() {
    const isDark = html.classList.contains('dark');
    moon?.classList.toggle('hidden', isDark);
    sun?.classList.toggle('hidden', !isDark);
  }

  applyIcon();

  toggle?.addEventListener('click', () => {
    html.classList.toggle('dark');
    localStorage.setItem('darkMode', html.classList.contains('dark').toString());
    applyIcon();
  });
</script>
