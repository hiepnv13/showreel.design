---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import ToolCard from "../../components/ToolCard.astro";

export const prerender = true;

const allTools = await getCollection('tools');
const tools = allTools.sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const categories = [
  'Animation Software',
  'Web & UI Animation',
  'AI Motion Tools',
  'Assets & Resources',
] as const;
---

<Layout
  title="Motion Design Tools — Showreel.design"
  description="The best software, apps, and tools for professional motion designers — from After Effects and Cinema 4D to AI video tools and web animation platforms."
  canonicalUrl="https://showreel.design/resources/tools"
>
  <Header />

  <main class="tools-page">

    <div class="tools-breadcrumb">
      <a href="/resources">Resources</a>
      <svg viewBox="0 0 16 16" fill="none">
        <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span>Tools</span>
    </div>

    <section class="tools-hero">
      <p class="tools-eyebrow">Resources / Tools</p>
      <h1 class="tools-title">Motion design tools<br />worth knowing.</h1>
      <p class="tools-subtitle">
        From industry-standard software to emerging AI tools — a curated list of
        what professional motion designers and studios actually use.
      </p>
    </section>

    <div class="tools-divider"></div>

    {categories.map((category) => {
      const categoryTools = tools.filter(t => t.data.category === category);
      if (categoryTools.length === 0) return null;
      return (
        <section class="tools-section">
          <div class="tools-section-header">
            <h2 class="tools-section-label">{category}</h2>
            <span class="tools-section-count">{categoryTools.length} tool{categoryTools.length > 1 ? 's' : ''}</span>
          </div>
          <div class="tools-grid">
            {categoryTools.map((tool) => (
              <ToolCard
                name={tool.data.name}
                category={tool.data.category}
                description={tool.data.description}
                pricing={tool.data.pricing}
                href={tool.data.href}
                thumbnail={tool.data.thumbnail}
                tags={tool.data.tags}
              />
            ))}
          </div>
          <div class="tools-divider"></div>
        </section>
      );
    })}

    <div class="tools-footer-note">
      <p>Know a tool that should be on this list? <a href="/about">Let us know →</a></p>
    </div>

  </main>

  <Footer />
</Layout>

<style>
  .tools-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 48px 32px 100px;
  }

  .tools-breadcrumb {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #bbb;
    margin-bottom: 48px;
  }

  .tools-breadcrumb a {
    color: #bbb;
    text-decoration: none;
    transition: color 0.2s;
  }

  .tools-breadcrumb a:hover { color: #111; }

  .tools-breadcrumb svg {
    width: 14px;
    height: 14px;
  }

  .tools-breadcrumb span { color: #111; }

  .tools-hero {
    padding-bottom: 64px;
  }

  .tools-eyebrow {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #bbb;
    margin-bottom: 28px;
  }

  .tools-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 400;
    letter-spacing: -1px;
    line-height: 1.15;
    color: #111;
    margin-bottom: 28px;
  }

  .tools-subtitle {
    font-size: 16px;
    line-height: 1.75;
    color: #888;
    max-width: 520px;
  }

  .tools-divider {
    width: 100%;
    height: 1px;
    background: #f0f0f0;
  }

  .tools-section {
    padding: 48px 0 0;
  }

  .tools-section-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 24px;
  }

  .tools-section-label {
    font-size: 18px;
    font-weight: 400;
    color: #111;
    margin: 0;
  }

  .tools-section-count {
    font-size: 11px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #bbb;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px 12px;
    margin-bottom: 48px;
  }

  .tools-footer-note {
    padding: 48px 0 0;
    text-align: center;
  }

  .tools-footer-note p {
    font-size: 14px;
    color: #aaa;
  }

  .tools-footer-note a {
    color: #111;
    text-decoration: underline;
    text-decoration-color: #ddd;
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .tools-footer-note a:hover {
    text-decoration-color: #111;
  }

  @media (max-width: 1024px) {
    .tools-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .tools-page { padding: 32px 16px 72px; }
    .tools-grid { grid-template-columns: repeat(2, 1fr); gap: 12px 8px; }
  }
</style>
