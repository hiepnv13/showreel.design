---
import {
    getVideosByCategorySlug,
    getAllCategories,
    sortVideosByDate,
    generateSlug,
} from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import FilterBar from "../../components/FilterBar.astro";

const { slug } = Astro.params;
const filter  = Astro.url.searchParams.get('filter') ?? '';
const pageNum = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'));

// Resolve category label from slug
const allCategories = await getAllCategories();
const category = allCategories.find(c => generateSlug(c) === slug) ?? slug!;

// Get + filter videos
const allVideos = await getVideosByCategorySlug(slug!);
const sorted = sortVideosByDate(allVideos);

const filtered = filter
  ? sorted.filter((v: any) => [
      ...(v.data.industries ?? []),
      ...(v.data.styles ?? []),
      ...(v.data.soundMusic ?? []),
    ].includes(filter))
  : sorted;

const itemsPerPage = 24;
const filterBaseUrl = `/category/${slug}`;
---

<Layout
  title={`${category} — Showreel.design`}
  description={`Curated ${category} motion design reels from studios and creators worldwide.`}
  canonicalUrl={`https://showreel.design/category/${slug}`}
>
    <main>
        <FilterBar videos={sorted} activeFilter={filter} filterBaseUrl={filterBaseUrl} />

        <VideoGrid
            videos={filtered}
            currentCategory={category}
            showAllTab={true}
            currentPage={pageNum}
            itemsPerPage={itemsPerPage}
            baseUrl={filterBaseUrl}
            filter={filter}
        />

        <!-- Empty State (only show if no videos in this category) -->
        {
            filtered.length === 0 && (
                <section class="py-20 bg-gray-50">
                    <div class="section-container">
                        <div class="text-center py-16">
                            <div class="text-gray-400 text-6xl mb-4">🎬</div>
                            <h3 class="text-2xl font-bold text-gray-900 mb-2">
                                No videos found
                            </h3>
                            <p class="text-gray-600 mb-8">
                                There are no videos in the {category} category
                                yet.
                            </p>
                            <a href="/" class="btn-primary">
                                Browse All Videos
                            </a>
                        </div>
                    </div>
                </section>
            )
        }
    </main>
</Layout>