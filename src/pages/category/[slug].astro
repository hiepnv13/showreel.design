---
import { getVideosByCategorySlug, getAllCategories, sortVideosByDate, generateSlug } from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import TopBar from "../../components/TopBar.astro";

const { slug } = Astro.params;
const url = Astro.url;

// Read multi-filter params
const activeIndustries = url.searchParams.get('industry')?.split(',').filter(Boolean) ?? [];
const activeStyles     = url.searchParams.get('style')?.split(',').filter(Boolean) ?? [];
const activeSounds     = url.searchParams.get('sound')?.split(',').filter(Boolean) ?? [];
const pageNum          = Math.max(1, parseInt(url.searchParams.get('page') ?? '1'));

// Resolve category label
const allCategories = await getAllCategories();
const category = allCategories.find(c => generateSlug(c) === slug) ?? slug!;

// All videos in this category (for filter options)
const allCategoryVideos = await getVideosByCategorySlug(slug!);
const sorted = sortVideosByDate(allCategoryVideos);

// Apply AND filtering: each active group must match
let filtered = sorted;
if (activeIndustries.length > 0) {
  filtered = filtered.filter((v: any) => activeIndustries.some(f => (v.data.industries ?? []).includes(f)));
}
if (activeStyles.length > 0) {
  filtered = filtered.filter((v: any) => activeStyles.some(f => (v.data.styles ?? []).includes(f)));
}
if (activeSounds.length > 0) {
  filtered = filtered.filter((v: any) => activeSounds.some(f => (v.data.soundMusic ?? []).includes(f)));
}

const itemsPerPage  = 24;
const filterBaseUrl = `/category/${slug}`;

// Serialize active filters for pagination
const filterParams = new URLSearchParams();
if (activeIndustries.length > 0) filterParams.set('industry', activeIndustries.join(','));
if (activeStyles.length > 0)     filterParams.set('style', activeStyles.join(','));
if (activeSounds.length > 0)     filterParams.set('sound', activeSounds.join(','));
---

<Layout
  title={`${category} — Showreel.design`}
  description={`Curated ${category} motion design reels from top studios and creators worldwide.`}
  canonicalUrl={`https://showreel.design/category/${slug}`}
>
  <main>
    <TopBar
      totalCount={sorted.length}
      filteredCount={filtered.length}
      category={category}
      allVideos={sorted}
      activeIndustries={activeIndustries}
      activeStyles={activeStyles}
      activeSounds={activeSounds}
      filterBaseUrl={filterBaseUrl}
      currentPage={pageNum}
    />

    <VideoGrid
      videos={filtered}
      currentPage={pageNum}
      itemsPerPage={itemsPerPage}
      baseUrl={filterBaseUrl}
      filterParams={filterParams.toString()}
    />

    {filtered.length === 0 && (
      <div class="empty-state">
        <p class="empty-hint">No videos match the selected filters.</p>
        <a href={filterBaseUrl} class="empty-clear">Clear filters</a>
      </div>
    )}
  </main>
</Layout>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 80px 24px;
    text-align: center;
  }
  .empty-hint { font-size: 14px; color: #bbb; }
  .empty-clear { font-size: 13px; color: #111; text-decoration: underline; }
</style>
