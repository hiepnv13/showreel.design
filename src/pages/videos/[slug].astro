---
import { getCollection, render, type CollectionEntry } from "astro:content";
import { getAllVideos, getRelatedVideos, generateSlug } from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import type { GetStaticPaths } from "astro";

export const prerender = true;

export const getStaticPaths: GetStaticPaths = async () => {
  const videos = await getAllVideos();
  return videos.map((video) => ({
    params: { slug: video.id },
    props: { video },
  }));
};

interface Props {
  video: CollectionEntry<"videos"> & {
    data: CollectionEntry<"videos">["data"] & {
      videoUrl: string;
      thumbnailUrl: string;
      previewUrl: string;
      videoSources: { src: string; type: string }[];
      videoFileName: string;
    };
  };
}

const { video }: Props = Astro.props;
const { Content } = await render(video);

const relatedVideos = await getRelatedVideos(video.id, video.data.category, 3);

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label: video.data.category, href: `/category/${generateSlug(video.data.category)}` },
  { label: video.data.title, href: '' }
];

function formatDuration(seconds: number | undefined): string {
  if (!seconds) return "N/A";
  const mins = Math.floor(seconds / 60);
  const secs = seconds % 60;
  return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
}

function formatTaxonomyValue(values: string[] | undefined): string {
  if (!values || values.length === 0) return "";
  return values
    .map(v => v.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' '))
    .join(', ');
}

const hasStyles = video.data.styles && video.data.styles.length > 0;
const hasTechniques = video.data.techniques && video.data.techniques.length > 0;
const hasSoundMusic = video.data.soundMusic && video.data.soundMusic.length > 0;
const hasTags = video.data.tags && video.data.tags.length > 0;
---

<Layout title={video.data.title}>
  <Header breadcrumb={breadcrumb} />

  <!-- Video Player — Full Width -->
  <div class="video-wrapper">
    <div class="video-player-container" id="video-container" data-playing="false" data-activated="false">

      <!-- Dark tint (fades out when playing) -->
      <div class="vp-overlay"></div>

      <!-- Title (fades out when playing) -->
      <div class="vp-title">
        <p class="vp-title-text">{video.data.title}</p>
        <p class="vp-title-author">by {video.data.author}</p>
      </div>

      <video
        id="main-video"
        class="main-video"
        autoplay
        muted
        playsinline
      >
        <source src={video.data.videoUrl} type="video/mp4" />
        <source src={`/videos/${encodeURIComponent(video.data.videoFileName)}`} type="video/mp4" />
      </video>

      <!-- Click feedback flash -->
      <div id="play-overlay" class="play-overlay">
        <div class="play-overlay-ring">
          <svg id="play-icon" class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
          <svg id="pause-icon" class="w-8 h-8 text-white hidden" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
          </svg>
        </div>
      </div>

      <!-- Video Controls Bar -->
      <div id="video-controls" class="video-controls">
        <button id="ctrl-play-pause" class="ctrl-btn" title="Play/Pause">
          <svg id="ctrl-play-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          <svg id="ctrl-pause-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
        </button>
        <span id="time-current" class="time-display">00:00</span>
        <div id="progress-container" class="progress-container">
          <div id="progress-bar" class="progress-bar">
            <div id="progress-filled" class="progress-filled"></div>
            <div id="progress-handle" class="progress-handle"></div>
          </div>
        </div>
        <span id="time-duration" class="time-display">00:00</span>
        <button id="ctrl-mute" class="ctrl-btn" title="Mute/Unmute">
          <svg id="ctrl-volume-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
          <svg id="ctrl-mute-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>
        </button>
        <div id="volume-container" class="volume-container">
          <div id="volume-bar" class="volume-bar">
            <div id="volume-filled" class="volume-filled"></div>
            <div id="volume-handle" class="volume-handle"></div>
          </div>
        </div>
        <button id="ctrl-fullscreen" class="ctrl-btn" title="Fullscreen">
          <svg id="ctrl-expand-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>
          <svg id="ctrl-compress-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>
        </button>
      </div>

      <!-- Custom cursor (scoped to player) -->
      <div id="vp-cursor" class="vp-cursor">
        <span id="vp-cursor-label" class="vp-cursor-label"></span>
      </div>

      <!-- Film Credits Overlay -->
      <div class="credits-overlay" id="credits-overlay">
        <!-- Scrolling credits -->
        <div class="credits-center" id="credits-center">
          <div class="credits-roll" id="credits-roll">
            <div class="c-title">{video.data.title}</div>
            <div class="c-author">by {video.data.author}</div>

            <div class="c-line"></div>

            <div class="c-row">
              <span class="c-role">Category</span>
              <span class="c-val">{video.data.category}</span>
            </div>
            {video.data.year && (
              <div class="c-row">
                <span class="c-role">Year</span>
                <span class="c-val">{video.data.year}</span>
              </div>
            )}
            {video.data.duration && (
              <div class="c-row">
                <span class="c-role">Duration</span>
                <span class="c-val">{formatDuration(video.data.duration)}</span>
              </div>
            )}
            {hasStyles && (
              <div class="c-row">
                <span class="c-role">Style</span>
                <span class="c-val">{formatTaxonomyValue(video.data.styles)}</span>
              </div>
            )}
            {hasTechniques && (
              <div class="c-row">
                <span class="c-role">Technique</span>
                <span class="c-val">{formatTaxonomyValue(video.data.techniques)}</span>
              </div>
            )}
            {hasSoundMusic && (
              <div class="c-row">
                <span class="c-role">Sound &amp; Music</span>
                <span class="c-val">{formatTaxonomyValue(video.data.soundMusic)}</span>
              </div>
            )}
            {hasTags && (
              <>
                <div class="c-line"></div>
                <div class="c-row c-tags-row">
                  <span class="c-role">Tags</span>
                  <span class="c-val">{video.data.tags.join(' · ')}</span>
                </div>
              </>
            )}
            {video.data.sourceUrl && (
              <div class="c-row">
                <span class="c-role">Link</span>
                <span class="c-val c-link">{video.data.sourceUrl.replace(/^https?:\/\//, '')}</span>
              </div>
            )}

            <div class="c-line"></div>

            <div class="c-replay-area">
              <button id="credits-replay-btn" class="c-replay-btn">↺ Replay</button>
            </div>

            <div class="credits-spacer"></div>
          </div>
        </div>

        <!-- Dismiss -->
        <button id="credits-dismiss" class="credits-dismiss-btn" title="Close">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Video Info (below video) -->
  <div class="video-info">
    <div class="info-header">
      <!-- Title + description -->
      <div class="info-title-area">
        <h1 class="info-title">{video.data.title}</h1>
        <p class="info-by">
          by <a href={`/author/${generateSlug(video.data.author)}`} class="info-author-link">{video.data.author}</a>
        </p>
        <p class="info-desc">{video.data.description}</p>
      </div>

      <!-- Project details table -->
      <div class="info-details-area">
        <h3 class="details-label">Project Details</h3>
        <div class="details-table">
          <div class="detail-row">
            <span class="detail-key">Year</span>
            <span class="detail-val">{video.data.year || "N/A"}</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">Duration</span>
            <span class="detail-val">{formatDuration(video.data.duration)}</span>
          </div>
          <div class="detail-row">
            <span class="detail-key">Category</span>
            <a href={`/category/${generateSlug(video.data.category)}`} class="detail-link">{video.data.category}</a>
          </div>
          {hasStyles && (
            <div class="detail-row">
              <span class="detail-key">Style</span>
              <span class="detail-val">{formatTaxonomyValue(video.data.styles)}</span>
            </div>
          )}
          {hasTechniques && (
            <div class="detail-row">
              <span class="detail-key">Technique</span>
              <span class="detail-val">{formatTaxonomyValue(video.data.techniques)}</span>
            </div>
          )}
          {hasSoundMusic && (
            <div class="detail-row">
              <span class="detail-key">Sound / Music</span>
              <span class="detail-val">{formatTaxonomyValue(video.data.soundMusic)}</span>
            </div>
          )}
          {video.data.sourceUrl && (
            <div class="detail-row">
              <span class="detail-key">Link</span>
              <a
                href={video.data.sourceUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="detail-link detail-link-truncate"
              >
                {video.data.sourceUrl.replace(/^https?:\/\//, '')}
              </a>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Tags -->
    {hasTags && (
      <div class="info-tags">
        <span class="tags-label">Tags</span>
        <div class="tags-list">
          {video.data.tags.map((tag: string) => (
            <a href={`/tag/${generateSlug(tag)}`} class="tag-pill">{tag}</a>
          ))}
        </div>
      </div>
    )}

    <!-- Markdown Description -->
    <div class="info-markdown">
      <div class="prose-content">
        <Content />
      </div>
    </div>
  </div>

  <!-- Related Videos -->
  {relatedVideos.length > 0 && (
    <section class="related-section">
      <p class="related-label">Explore more</p>
      <div class="related-grid">
        {relatedVideos.map((relatedVideo) => (
          <a href={`/videos/${relatedVideo.id}`} class="related-item group">
            <div class="related-thumb">
              <video
                class="related-video"
                muted
                loop
                playsinline
                preload="none"
                data-src={(relatedVideo.data as any).thumbnailUrl}
              >
                <source data-src={(relatedVideo.data as any).thumbnailUrl} type="video/mp4" />
              </video>
            </div>
            <p class="related-title">{relatedVideo.data.title}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <Footer />
</Layout>

<style>
  /* ─── Video Player ─────────────────────────────────────── */
  .video-wrapper {
    width: 100%;
    background: #000;
  }

  .video-player-container {
    width: 100%;
    height: calc(100vh - 140px);
    background: #000;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .main-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ─── Dark Tint Overlay ───────────────────────────────── */
  .vp-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.32);
    transition: opacity 0.7s ease;
    pointer-events: none;
    z-index: 1;
  }

  .video-player-container[data-playing="true"] .vp-overlay {
    opacity: 0;
  }

  /* ─── Title Overlay ────────────────────────────────────── */
  .vp-title {
    position: absolute;
    bottom: 52px;
    left: 0;
    right: 0;
    padding: 40px 28px 18px;
    background: linear-gradient(transparent, rgba(0,0,0,0.45));
    z-index: 5;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .vp-title-text {
    font-size: 20px;
    font-weight: 400;
    letter-spacing: 0.5px;
    color: rgba(255,255,255,0.88);
    line-height: 1.3;
    margin: 0 0 6px;
  }

  .vp-title-author {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.38);
    margin: 0;
  }

  .video-player-container[data-playing="true"] .vp-title {
    opacity: 0;
  }

  /* ─── Play/Pause Overlay ───────────────────────────────── */
  .play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    z-index: 8;
  }

  .play-overlay-ring {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    padding: 32px;
  }

  /* ─── Custom Cursor ───────────────────────────────────── */
  .video-player-container {
    cursor: none;
  }

  .vp-cursor {
    position: absolute;
    top: 0; left: 0;
    width: 54px;
    height: 54px;
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: 50%;
    pointer-events: none;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(-50%, -50%) scale(0);
    transition: border-color 0.2s, width 0.2s, height 0.2s;
    will-change: transform;
    opacity: 0;
  }

  .video-player-container:hover .vp-cursor {
    opacity: 1;
  }

  .vp-cursor.active {
    transform: translate(var(--cx), var(--cy)) translate(-50%, -50%) scale(1);
  }

  .vp-cursor.pressing {
    width: 40px;
    height: 40px;
    border-color: rgba(255,255,255,0.6);
  }

  /* Snap to progress bar: smaller ring, brighter */
  .vp-cursor.on-progress {
    width: 40px;
    height: 40px;
    border-color: rgba(255,255,255,0.7);
    transition: width 0.12s, height 0.12s, border-color 0.12s;
  }

  .vp-cursor-label {
    font-family: 'Aileron', sans-serif;
    font-size: 8px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    user-select: none;
  }

  /* ─── Video Controls ───────────────────────────────────── */
  .video-controls {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 16px 14px;
    background: linear-gradient(transparent, rgba(0,0,0,0.65));
    opacity: 1;
    transition: opacity 0.4s ease;
    z-index: 10;
  }

  .video-player-container[data-playing="true"] .video-controls {
    opacity: 0;
  }

  .video-player-container:hover .video-controls {
    opacity: 1 !important;
  }

  .ctrl-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.3);
    border-radius: 2px;
    color: white;
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .ctrl-btn:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.5);
  }

  .time-display {
    font-size: 10px;
    letter-spacing: 0.5px;
    color: rgba(255,255,255,0.8);
    font-family: 'Aileron', sans-serif;
    min-width: 40px;
    flex-shrink: 0;
  }

  .progress-container {
    flex: 1;
    height: 32px;
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 0 4px;
  }

  .progress-bar {
    position: relative;
    width: 100%;
    height: 2px;
    background: rgba(255,255,255,0.15);
    border-radius: 0;
    transition: height 0.15s;
  }

  .progress-container:hover .progress-bar { height: 3px; }

  .progress-filled {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    background: white;
    border-radius: 0;
    width: 0%;
  }

  .progress-handle {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 1.5px;
    height: 14px;
    background: white;
    border-radius: 0;
    opacity: 0;
    transition: opacity 0.2s;
    left: 0%;
  }

  .progress-container:hover .progress-handle { opacity: 1; }

  .volume-container {
    width: 60px;
    height: 32px;
    display: flex;
    align-items: center;
    cursor: pointer;
    padding: 0 4px;
    flex-shrink: 0;
  }

  .volume-bar {
    position: relative;
    width: 100%;
    height: 3px;
    background: rgba(255,255,255,0.2);
    border-radius: 2px;
  }

  .volume-filled {
    position: absolute;
    top: 0; left: 0;
    height: 100%;
    background: white;
    border-radius: 2px;
    width: 25%;
  }

  .volume-handle {
    position: absolute;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 10px;
    height: 10px;
    background: white;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 0.2s;
    left: 25%;
  }

  .volume-container:hover .volume-handle { opacity: 1; }

  .video-player-container:fullscreen { max-height: 100vh; }

  /* ─── Film Credits Overlay ─────────────────────────────── */
  .credits-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    background: rgba(0, 0, 0, 0.97);
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.2s ease;
    z-index: 40;
    overflow: hidden;
  }

  .credits-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Credits center */
  .credits-center {
    flex: 1;
    position: relative;
    overflow: hidden;
  }

  .credits-roll {
    position: absolute;
    left: 0;
    right: 0;
    top: 0;
    text-align: center;
    will-change: transform;
  }

  .credits-spacer {
    height: 160px;
  }

  /* Credit text */
  .c-title {
    font-size: 18px;
    letter-spacing: 5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.92);
    margin-bottom: 10px;
    padding: 0 32px;
    line-height: 1.4;
  }

  .c-author {
    font-size: 10px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 48px;
  }

  .c-line {
    width: 48px;
    height: 1px;
    background: rgba(255,255,255,0.12);
    margin: 36px auto;
  }

  .c-row {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 24px;
    margin-bottom: 12px;
    padding: 0 24px;
  }

  .c-role {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.32);
    text-align: right;
    width: 150px;
    flex-shrink: 0;
  }

  .c-val {
    font-size: 12px;
    letter-spacing: 0.3px;
    color: rgba(255,255,255,0.82);
    text-align: left;
    width: 200px;
    flex-shrink: 0;
    line-height: 1.5;
  }

  .c-tags-row .c-val {
    width: 240px;
  }

  .c-link {
    font-size: 10px;
    color: rgba(255,255,255,0.45);
    word-break: break-all;
    width: 200px;
  }

  .c-replay-area {
    text-align: center;
    margin-top: 8px;
  }

  .c-replay-btn {
    font-family: 'Aileron', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 10px 28px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
    border-radius: 1px;
  }

  .c-replay-btn:hover {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.35);
  }

  .credits-dismiss-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 2px;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s, border-color 0.2s;
    z-index: 10;
  }

  .credits-dismiss-btn:hover {
    color: rgba(255,255,255,0.85);
    border-color: rgba(255,255,255,0.35);
  }

  /* ─── Video Info Section ───────────────────────────────── */
  .video-info {
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 80px 40px;
  }

  .info-header {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 80px;
    padding-bottom: 48px;
    border-bottom: 1px solid #f0f0f0;
  }

  .info-title {
    font-size: 34px;
    line-height: 1.2;
    letter-spacing: -0.5px;
    color: #111;
    margin-bottom: 12px;
  }

  .info-by {
    font-size: 13px;
    color: #aaa;
    margin-bottom: 24px;
  }

  .info-author-link {
    color: #555;
    text-decoration: none;
    border-bottom: 1px solid #e0e0e0;
    transition: border-color 0.2s, color 0.2s;
  }

  .info-author-link:hover {
    color: #111;
    border-color: #111;
  }

  .info-desc {
    font-size: 15px;
    line-height: 1.75;
    color: #888;
  }

  .details-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #bbb;
    margin-bottom: 16px;
  }

  .details-table {
    display: flex;
    flex-direction: column;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px solid #f3f3f3;
    gap: 16px;
  }

  .detail-key {
    font-size: 11px;
    color: #bbb;
    flex-shrink: 0;
    letter-spacing: 0.3px;
  }

  .detail-val {
    font-size: 12px;
    color: #333;
    text-align: right;
  }

  .detail-link {
    font-size: 12px;
    color: #333;
    text-decoration: none;
    border-bottom: 1px solid #ececec;
    transition: border-color 0.2s;
  }

  .detail-link:hover { border-color: #333; }

  .detail-link-truncate {
    max-width: 220px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    display: block;
    text-align: right;
  }

  /* Tags */
  .info-tags {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 28px 0;
    border-bottom: 1px solid #f0f0f0;
  }

  .tags-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #bbb;
    flex-shrink: 0;
  }

  .tags-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-pill {
    font-size: 11px;
    letter-spacing: 0.3px;
    color: #777;
    background: #f5f5f5;
    padding: 5px 12px;
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .tag-pill:hover {
    background: #ebebeb;
    color: #111;
  }

  /* Markdown prose */
  .info-markdown {
    padding-top: 40px;
  }

  .prose-content {
    font-size: 14px;
    line-height: 1.85;
    color: #777;
    max-width: 680px;
  }

  .prose-content h1,
  .prose-content h2,
  .prose-content h3 {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #aaa;
    margin-top: 32px;
    margin-bottom: 12px;
    font-weight: 400;
  }

  .prose-content p { margin-bottom: 14px; }

  .prose-content ul,
  .prose-content ol {
    margin-bottom: 14px;
    padding-left: 20px;
  }

  .prose-content li { margin-bottom: 6px; }

  .prose-content strong {
    color: #444;
    font-weight: 500;
  }

  /* ─── Related Videos ───────────────────────────────────── */
  .related-section {
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 80px 60px;
    border-top: 1px solid #f0f0f0;
  }

  .related-label {
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #bbb;
    text-align: center;
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .related-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
  }

  .related-thumb {
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #f3f3f3;
  }

  .related-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.5s ease, transform 0.7s ease;
  }

  .related-video.loaded { opacity: 1; }

  .related-item:hover .related-video { transform: scale(1.04); }

  .related-title {
    font-size: 12px;
    color: #555;
    padding: 0 2px;
    transition: color 0.15s;
  }

  .related-item:hover .related-title { color: #111; }

  /* ─── Responsive ───────────────────────────────────────── */
  @media (max-width: 1023px) {
    .video-player-container {
      height: 56vw;
      min-height: 260px;
    }

    .video-info {
      padding: 40px 24px 32px;
    }

    .info-header {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .related-section {
      padding: 32px 24px 48px;
    }

    .related-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .film-perf {
      width: 28px;
    }

    .perf-hole {
      width: 14px;
      height: 11px;
    }

    .c-title {
      font-size: 14px;
      letter-spacing: 3px;
    }

    .c-row { gap: 14px; }

    .c-role { width: 110px; font-size: 8px; }
    .c-val  { width: 140px; font-size: 11px; }
    .c-tags-row .c-val { width: 160px; }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .volume-container { display: none; }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const video = document.getElementById("main-video") as HTMLVideoElement;
    const playOverlay = document.getElementById("play-overlay");
    const playIcon = document.getElementById("play-icon");
    const pauseIcon = document.getElementById("pause-icon");
    const ctrlPlayPause = document.getElementById("ctrl-play-pause");
    const ctrlPlayIcon = document.getElementById("ctrl-play-icon");
    const ctrlPauseIcon = document.getElementById("ctrl-pause-icon");
    const ctrlMute = document.getElementById("ctrl-mute");
    const ctrlVolumeIcon = document.getElementById("ctrl-volume-icon");
    const ctrlMuteIcon = document.getElementById("ctrl-mute-icon");
    const ctrlFullscreen = document.getElementById("ctrl-fullscreen");
    const ctrlExpandIcon = document.getElementById("ctrl-expand-icon");
    const ctrlCompressIcon = document.getElementById("ctrl-compress-icon");
    const timeCurrent = document.getElementById("time-current");
    const timeDuration = document.getElementById("time-duration");
    const progressContainer = document.getElementById("progress-container");
    const progressFilled = document.getElementById("progress-filled");
    const progressHandle = document.getElementById("progress-handle");
    const volumeContainer = document.getElementById("volume-container");
    const volumeFilled = document.getElementById("volume-filled");
    const volumeHandle = document.getElementById("volume-handle");

    // Credits elements
    const creditsOverlay = document.getElementById("credits-overlay");
    const creditsCenter = document.getElementById("credits-center");
    const creditsRoll = document.getElementById("credits-roll");
    const creditsDismiss = document.getElementById("credits-dismiss");
    const creditsReplayBtn = document.getElementById("credits-replay-btn");

    // ── Helpers ──────────────────────────────────────────────
    function formatTime(s: number): string {
      if (isNaN(s)) return "00:00";
      const m = Math.floor(s / 60);
      const sec = Math.floor(s % 60);
      return `${m.toString().padStart(2, '0')}:${sec.toString().padStart(2, '0')}`;
    }

    function updatePlayPauseIcons(playing: boolean) {
      ctrlPlayIcon?.classList.toggle("hidden", playing);
      ctrlPauseIcon?.classList.toggle("hidden", !playing);
      playIcon?.classList.toggle("hidden", playing);
      pauseIcon?.classList.toggle("hidden", !playing);
    }

    function updateVolumeIcons(muted: boolean) {
      ctrlVolumeIcon?.classList.toggle("hidden", muted);
      ctrlMuteIcon?.classList.toggle("hidden", !muted);
    }

    function updateProgress() {
      if (!video) return;
      const pct = (video.currentTime / video.duration) * 100;
      if (progressFilled) progressFilled.style.width = `${pct}%`;
      if (progressHandle) progressHandle.style.left = `${pct}%`;
      if (timeCurrent) timeCurrent.textContent = formatTime(video.currentTime);
    }

    function updateVolumeBar(vol: number) {
      if (volumeFilled) volumeFilled.style.width = `${vol * 100}%`;
      if (volumeHandle) volumeHandle.style.left = `${vol * 100}%`;
    }

    // ── Video ─────────────────────────────────────────────────
    const container = document.getElementById("video-container");

    if (video) {
      video.muted = true;
      video.volume = 0;

      video.addEventListener("loadedmetadata", () => {
        if (timeDuration) timeDuration.textContent = formatTime(video.duration);
      });

      video.addEventListener("timeupdate", updateProgress);

      video.addEventListener("play", () => {
        updatePlayPauseIcons(true);
        container?.setAttribute("data-playing", "true");
        container?.setAttribute("data-activated", "true");
      });

      video.addEventListener("pause", () => {
        updatePlayPauseIcons(false);
        container?.setAttribute("data-playing", "false");
      });

      // Trigger film credits when video ends
      video.addEventListener("ended", () => {
        showCredits();
      });

      let hasInteracted = false;
      function unmute() {
        if (hasInteracted) return;
        hasInteracted = true;
        video.muted = false;
        let vol = 0;
        const fade = setInterval(() => {
          vol = Math.min(vol + 0.05, 0.25);
          video.volume = vol;
          if (vol >= 0.25) clearInterval(fade);
        }, 200);
      }

      video.addEventListener("click", (e) => {
        e.preventDefault();
        unmute();
        if (video.paused) {
          video.play();
        } else {
          video.pause();
        }
        if (playOverlay) {
          playOverlay.classList.remove("opacity-0", "pointer-events-none");
          setTimeout(() => playOverlay.classList.add("opacity-0", "pointer-events-none"), 300);
        }
      });

      ctrlPlayPause?.addEventListener("click", (e) => {
        e.stopPropagation();
        video.paused ? video.play() : video.pause();
      });

      ctrlMute?.addEventListener("click", (e) => {
        e.stopPropagation();
        video.muted = !video.muted;
        updateVolumeIcons(video.muted);
        if (!video.muted && video.volume === 0) {
          video.volume = 0.25;
          updateVolumeBar(0.25);
        }
      });

      video.addEventListener("volumechange", () => {
        updateVolumeIcons(video.muted || video.volume === 0);
        if (!video.muted) updateVolumeBar(video.volume);
      });

      // Progress scrubbing
      let draggingProgress = false;
      function seekTo(e: MouseEvent) {
        if (!progressContainer || !video) return;
        const rect = progressContainer.getBoundingClientRect();
        const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        video.currentTime = pct * video.duration;
      }
      progressContainer?.addEventListener("mousedown", (e) => { draggingProgress = true; seekTo(e); });
      document.addEventListener("mousemove", (e) => { if (draggingProgress) seekTo(e); });
      document.addEventListener("mouseup", () => { draggingProgress = false; });

      // Volume scrubbing
      let draggingVolume = false;
      function setVolFromPos(e: MouseEvent) {
        if (!volumeContainer || !video) return;
        const rect = volumeContainer.getBoundingClientRect();
        const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
        video.volume = pct;
        video.muted = false;
        updateVolumeBar(pct);
        updateVolumeIcons(pct === 0);
      }
      volumeContainer?.addEventListener("mousedown", (e) => { draggingVolume = true; setVolFromPos(e); });
      document.addEventListener("mousemove", (e) => { if (draggingVolume) setVolFromPos(e); });
      document.addEventListener("mouseup", () => { draggingVolume = false; });

      // Fullscreen
      ctrlFullscreen?.addEventListener("click", (e) => {
        e.stopPropagation();
        if (!document.fullscreenElement) {
          container?.requestFullscreen();
        } else {
          document.exitFullscreen();
        }
      });

      document.addEventListener("fullscreenchange", () => {
        const inFS = !!document.fullscreenElement;
        ctrlExpandIcon?.classList.toggle("hidden", inFS);
        ctrlCompressIcon?.classList.toggle("hidden", !inFS);
      });

      updateVolumeBar(video.volume);

      // Sync state if video is already playing (autoplay)
      if (!video.paused) {
        container?.setAttribute("data-playing", "true");
        container?.setAttribute("data-activated", "true");
        updatePlayPauseIcons(true);
      }
    }

    // ── Custom Cursor ─────────────────────────────────────────
    const vpCursor = document.getElementById('vp-cursor');
    const vpCursorLabel = document.getElementById('vp-cursor-label');
    const videoContainer2 = document.getElementById('video-container');

    if (vpCursor && videoContainer2) {
      const cursor = vpCursor as HTMLElement;
      let cx = 0, cy = 0;      // target (mouse)
      let rx2 = 0, ry2 = 0;    // lerped
      let onProgress = false;
      let cursorRaf: number;

      function fmt(s: number) {
        if (isNaN(s)) return '0:00';
        const m = Math.floor(s / 60);
        const sec = Math.floor(s % 60);
        return `${m}:${sec.toString().padStart(2,'0')}`;
      }

      function updateCursorLabel() {
        if (!vpCursorLabel || !videoContainer2) return;
        if (onProgress) return;
        const creditsVisible = document.getElementById('credits-overlay')?.classList.contains('visible');
        if (creditsVisible) { vpCursorLabel.textContent = 'Replay'; return; }
        const playing = videoContainer2.getAttribute('data-playing') === 'true';
        vpCursorLabel.textContent = playing ? 'Pause' : 'Play';
      }

      function tickCursor() {
        cursor.style.setProperty('--cx', `${cx}px`);
        cursor.style.setProperty('--cy', `${cy}px`);
        cursorRaf = requestAnimationFrame(tickCursor);
      }

      // Progress bar: snap cursor + show time
      const progressContainer2 = document.getElementById('progress-container');
      if (progressContainer2) {
        progressContainer2.addEventListener('mouseenter', () => {
          onProgress = true;
          cursor.classList.add('on-progress');
        });

        progressContainer2.addEventListener('mousemove', (e) => {
          const rect = progressContainer2.getBoundingClientRect();
          const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          const containerRect = videoContainer2.getBoundingClientRect();
          // snap X along progress bar, Y to center of progress bar
          cx = e.clientX - containerRect.left;
          cy = rect.top + rect.height / 2 - containerRect.top;
          if (vpCursorLabel && video) {
            vpCursorLabel.textContent = fmt(pct * (video.duration || 0));
          }
        });

        progressContainer2.addEventListener('mouseleave', () => {
          onProgress = false;
          cursor.classList.remove('on-progress');
          updateCursorLabel();
        });
      }

      videoContainer2.addEventListener('mouseenter', () => {
        cursor.classList.add('active');
        // Snap to current mouse position on entry (no lag flash)
        rx2 = cx; ry2 = cy;
        updateCursorLabel();
        tickCursor();
      });

      videoContainer2.addEventListener('mouseleave', () => {
        cursor.classList.remove('active');
        onProgress = false;
        cursor.classList.remove('on-progress');
        cancelAnimationFrame(cursorRaf);
      });

      videoContainer2.addEventListener('mousemove', (e) => {
        if (onProgress) return; // handled by progress listener
        const rect = videoContainer2.getBoundingClientRect();
        cx = e.clientX - rect.left;
        cy = e.clientY - rect.top;
        updateCursorLabel();
      });

      videoContainer2.addEventListener('mousedown', () => cursor.classList.add('pressing'));
      videoContainer2.addEventListener('mouseup', () => cursor.classList.remove('pressing'));

      video?.addEventListener('play', updateCursorLabel);
      video?.addEventListener('pause', updateCursorLabel);
      video?.addEventListener('ended', () => requestAnimationFrame(updateCursorLabel));
      document.addEventListener('credits:hide', updateCursorLabel);
    }

    // ── Film Credits ──────────────────────────────────────────
    function showCredits() {
      if (!creditsOverlay || !creditsCenter || !creditsRoll) return;

      // Reveal overlay first so dimensions are valid
      creditsOverlay.classList.add("visible");

      const centerH = creditsCenter.clientHeight;
      const rollH = creditsRoll.scrollHeight;
      const duration = Math.max(15, (centerH + rollH) / 50);

      // Set start position with no transition
      creditsRoll.style.transition = "none";
      creditsRoll.style.transform = `translateY(${centerH}px)`;

      // Double rAF: wait for browser to paint the start position before animating
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          creditsRoll.style.transition = `transform ${duration}s linear`;
          creditsRoll.style.transform = `translateY(-${rollH}px)`;

          creditsRoll.addEventListener("transitionend", () => {
            hideCredits();
          }, { once: true });
        });
      });
    }

    function hideCredits() {
      if (!creditsOverlay || !creditsRoll) return;
      creditsOverlay.classList.remove("visible");
      creditsRoll.style.transition = "none";
      document.dispatchEvent(new CustomEvent('credits:hide'));
    }

    function replayVideo() {
      hideCredits();
      if (video) {
        video.currentTime = 0;
        video.play();
      }
    }

    creditsDismiss?.addEventListener("click", hideCredits);
    creditsReplayBtn?.addEventListener("click", replayVideo);

    // ── Related Videos Lazy Load ──────────────────────────────
    const relatedVids = document.querySelectorAll<HTMLVideoElement>('.related-video');
    const loadedSet = new WeakSet<HTMLVideoElement>();

    const loadObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const vid = entry.target as HTMLVideoElement;
        if (loadedSet.has(vid)) return;
        const src = vid.getAttribute('data-src');
        if (!src) return;
        const source = vid.querySelector('source');
        if (source) source.src = src;
        vid.src = src;
        vid.addEventListener('canplay', () => {
          loadedSet.add(vid);
          vid.classList.add('loaded');
        }, { once: true });
        vid.load();
      });
    }, { rootMargin: '100px', threshold: 0.1 });

    relatedVids.forEach(v => loadObserver.observe(v));

    document.querySelectorAll('.related-item').forEach(item => {
      const vid = item.querySelector('video') as HTMLVideoElement;
      if (!vid) return;
      item.addEventListener('mouseenter', () => {
        if (loadedSet.has(vid)) { vid.currentTime = 0; vid.play().catch(() => {}); }
      });
      item.addEventListener('mouseleave', () => vid.pause());
    });
  });
</script>
