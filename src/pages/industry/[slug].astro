---
export const prerender = true;

import {
  getVideosByIndustry,
  getAllIndustries,
  getIndustryLabel,
  sortVideosByDate,
} from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const industries = await getAllIndustries();
  return industries.map((slug: string) => ({
    params: { slug },
    props: { slug },
  }));
};

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const allIndustries = await getAllIndustries();
const label = getIndustryLabel(slug);

const allVideos = await getVideosByIndustry(slug);
const videos = sortVideosByDate(allVideos);
const itemsPerPage = 24;
const totalCount = videos.length;
const showingCount = Math.min(itemsPerPage, totalCount);

const breadcrumb = [
  { label: 'Home', href: '/' },
  { label, href: '' },
];
---

<Layout title={`${label} Motion Design — Showreel.design`}>
  <Header showingCount={showingCount} totalCount={totalCount} breadcrumb={breadcrumb} />

  <!-- Industry filter chips -->
  <div class="industry-chips">
    {allIndustries.map((ind) => (
      <a
        href={`/industry/${ind}`}
        class={`filter-btn${ind === slug ? ' active' : ''}`}
      >
        {getIndustryLabel(ind)}
      </a>
    ))}
  </div>

  <VideoGrid
    videos={videos}
    currentPage={1}
    itemsPerPage={itemsPerPage}
    baseUrl={`/industry/${slug}`}
  />
  <Footer />
</Layout>

<style>
  .industry-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    flex-wrap: wrap;
  }
</style>
