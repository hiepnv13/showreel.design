---
export const prerender = true;

import { getVideosByIndustry, getAllIndustries, getIndustryLabel, sortVideosByDate } from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import TopBar from "../../components/TopBar.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const industries = await getAllIndustries();
  return industries.map((slug: string) => ({
    params: { slug },
    props: { slug },
  }));
};

interface Props { slug: string; }
const { slug } = Astro.props;

const label = getIndustryLabel(slug);
const videos = sortVideosByDate(await getVideosByIndustry(slug));
const itemsPerPage = 24;
---

<Layout
  title={`${label} Motion Design Showreels — Showreel.design`}
  description={`Curated ${label} motion design reels from top studios and creators worldwide.`}
  canonicalUrl={`https://showreel.design/industry/${slug}`}
>
  <main>
    <TopBar
      totalCount={videos.length}
      allVideos={videos}
      h1Text={`Discover ${videos.length} Best Showreels Made for ${label}`}
      h2Text={`Curated showreels crafted for ${label} — top studios and creators worldwide.`}
    />
    <VideoGrid videos={videos} currentPage={1} itemsPerPage={itemsPerPage} baseUrl={`/industry/${slug}`} />
  </main>
</Layout>
