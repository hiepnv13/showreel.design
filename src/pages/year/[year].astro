---
export const prerender = true;

import { getVideosByYear, getAllYears, sortVideosByDate } from "../../utils/videoUtils";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import TopBar from "../../components/TopBar.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const years = await getAllYears();
  return years.map((year: number) => ({
    params: { year: String(year) },
    props: { year },
  }));
};

interface Props { year: number; }

const { year } = Astro.props;
const allYears = await getAllYears();
const videos = sortVideosByDate(await getVideosByYear(year));
const itemsPerPage = 24;
---

<Layout
  title={`${year} Showreels — Showreel.design`}
  description={`Curated ${year} motion design reels from top studios and creators worldwide.`}
  canonicalUrl={`https://showreel.design/year/${year}`}
>
  <main>
    <TopBar
      totalCount={videos.length}
      allVideos={videos}
      h1Text={`Discover ${videos.length} Best ${year} Showreels`}
      h2Text={`The best showreels from ${year} — studios and creators worldwide.`}
    />

    <!-- Year navigation chips — below TopBar -->
    <div class="year-chips">
      {allYears.map((y) => (
        <a href={`/year/${y}`} class={`filter-btn${y === year ? ' active' : ''}`}>{y}</a>
      ))}
    </div>

    <VideoGrid videos={videos} currentPage={1} itemsPerPage={itemsPerPage} baseUrl={`/year/${year}`} />
  </main>
</Layout>

<style>
  .year-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    flex-wrap: wrap;
    border-bottom: 1px solid #f0f0f0;
  }
</style>
