---
export const prerender = true;

import { getAllStyles, getVideosByStyle, sortVideosByDate } from "../../utils/videoUtils";
import { getTaxonomyLabel } from "../../config/taxonomies";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const styles = await getAllStyles();
  return styles.map((slug: string) => ({
    params: { slug },
    props: { slug },
  }));
};

interface Props { slug: string; }
const { slug } = Astro.props;

const allStyles = await getAllStyles();
const label = getTaxonomyLabel('styles', slug);
const videos = sortVideosByDate(await getVideosByStyle(slug));
const itemsPerPage = 24;
---

<Layout title={`${label} Motion Design — Showreel.design`}>
  <div class="style-chips">
    {allStyles.map(s => (
      <a href={`/style/${s}`} class={`filter-btn${s === slug ? ' active' : ''}`}>
        {getTaxonomyLabel('styles', s)}
      </a>
    ))}
  </div>

  <VideoGrid videos={videos} currentPage={1} itemsPerPage={itemsPerPage} baseUrl={`/style/${slug}`} />
</Layout>

<style>
  .style-chips {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    flex-wrap: wrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .style-chips::-webkit-scrollbar { display: none; }
  @media (min-width: 640px) {
    .style-chips { padding: 16px 32px; flex-wrap: wrap; overflow-x: visible; }
  }
</style>