---
export const prerender = true;

import { getAllStyles, getVideosByStyle, sortVideosByDate } from "../../utils/videoUtils";
import { getTaxonomyLabel } from "../../config/taxonomies";
import Layout from "../../layouts/Layout.astro";
import VideoGrid from "../../components/VideoGrid.astro";
import TopBar from "../../components/TopBar.astro";
import type { GetStaticPaths } from "astro";

export const getStaticPaths: GetStaticPaths = async () => {
  const styles = await getAllStyles();
  return styles.map((slug: string) => ({
    params: { slug },
    props: { slug },
  }));
};

interface Props { slug: string; }
const { slug } = Astro.props;

const label = getTaxonomyLabel('styles', slug);
const videos = sortVideosByDate(await getVideosByStyle(slug));
const itemsPerPage = 24;
---

<Layout
  title={`${label} Showreels — Showreel.design`}
  description={`Curated ${label} motion design reels from top studios and creators worldwide.`}
  canonicalUrl={`https://showreel.design/style/${slug}`}
>
  <main>
    <TopBar
      totalCount={videos.length}
      allVideos={videos}
      h1Text={`Discover ${videos.length} Best ${label} Showreels`}
      h2Text={`Curated ${label} showreels from top studios and creators worldwide.`}
    />
    <VideoGrid videos={videos} currentPage={1} itemsPerPage={itemsPerPage} baseUrl={`/style/${slug}`} />
  </main>
</Layout>
