---
import Layout from "../layouts/Layout.astro";
import VideoGrid from "../components/VideoGrid.astro";
import { searchVideos, sortVideosByDate } from "../utils/videoUtils";
import type { CollectionEntry } from 'astro:content';

const url = Astro.url;
const query = url.searchParams.get('q') || '';
const pageParam = url.searchParams.get('page') || '1';
const currentPage = parseInt(pageParam);
const itemsPerPage = 24;

let videos: CollectionEntry<'videos'>[] = [];
let searchPerformed = false;
let totalCount = 0;
let totalPages = 1;

if (query.trim()) {
  const searchResults = await searchVideos(query.trim());
  const allResults = sortVideosByDate(searchResults);
  totalCount = allResults.length;
  totalPages = Math.ceil(totalCount / itemsPerPage);

  const startIndex = (currentPage - 1) * itemsPerPage;
  videos = allResults.slice(startIndex, startIndex + itemsPerPage);
  searchPerformed = true;
}
---

<Layout title={query ? `"${query}" — Showreel.design` : "Search — Showreel.design"}>

  {searchPerformed && (
    <div class="search-results-label">
      <span>{totalCount} showreel{totalCount !== 1 ? 's' : ''} for "<strong>{query}</strong>"</span>
    </div>
  )}

  <div class="search-body">
  {!searchPerformed && (
    <div class="empty-state">
      <p class="empty-hint">Use the search in the sidebar to find showreels.</p>
    </div>
  )}

  {searchPerformed && videos.length === 0 && (
    <div class="empty-state">
      <p class="empty-query">"{query}"</p>
      <p class="empty-hint">No results found. Try a different keyword.</p>
    </div>
  )}

  {searchPerformed && videos.length > 0 && (
    <VideoGrid
      videos={videos}
      showAllTab={false}
      currentPage={currentPage}
      itemsPerPage={itemsPerPage}
      baseUrl={`/search?q=${encodeURIComponent(query)}`}
    />
  )}
  </div>

</Layout>

<style>
  .search-results-label {
    padding: 12px 32px;
    font-size: 13px;
    color: #888;
    border-bottom: 1px solid #f0f0f0;
  }

  .search-results-label strong {
    color: #111;
    font-weight: 500;
  }

  .search-body {
    min-height: calc(100vh - 140px);
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 120px 24px;
    text-align: center;
  }

  .empty-query {
    font-size: 24px;
    font-weight: 400;
    letter-spacing: -0.3px;
    color: #111;
  }

  .empty-hint {
    font-size: 13px;
    color: #bbb;
    letter-spacing: 0.2px;
  }
</style>

<script>
  import '../scripts/gridActions.js';
</script>
