---
import Layout from "../layouts/Layout.astro";
import VideoGrid from "../components/VideoGrid.astro";
import FilterBar from "../components/FilterBar.astro";
import { getAllVideos, sortVideosByDate } from "../utils/videoUtils";

const filter  = Astro.url.searchParams.get('filter') ?? '';
const pageNum = Math.max(1, parseInt(Astro.url.searchParams.get('page') ?? '1'));

const allVideos = await getAllVideos();
const sorted = sortVideosByDate(allVideos);

const filtered = filter
  ? sorted.filter((v: any) => [
      ...(v.data.industries ?? []),
      ...(v.data.styles ?? []),
      ...(v.data.soundMusic ?? []),
    ].includes(filter))
  : sorted;

const itemsPerPage = 24;
---

<Layout title="Showreel.design - Discover amazing showreels">
    <FilterBar videos={sorted} activeFilter={filter} filterBaseUrl="/" />
    <VideoGrid
        videos={filtered}
        currentPage={pageNum}
        itemsPerPage={itemsPerPage}
        baseUrl="/"
        filter={filter}
    />
</Layout>
