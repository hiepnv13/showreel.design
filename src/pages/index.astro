---
import Layout from "../layouts/Layout.astro";
import VideoGrid from "../components/VideoGrid.astro";
import TopBar from "../components/TopBar.astro";
import { getAllVideos, sortVideosByDate } from "../utils/videoUtils";

export const prerender = true;

const allVideos = await getAllVideos();
const videos = sortVideosByDate(allVideos);
const itemsPerPage = 24;
---

<Layout title="Showreel.design — Discover the Best Showreels">
  <main>
    <TopBar
      totalCount={videos.length}
      allVideos={videos}
      h1Text={`Discover ${videos.length} Best Showreels`}
      h2Text="The best motion design reels from top studios and creators worldwide."
    />
    <VideoGrid
      videos={videos}
      currentPage={1}
      itemsPerPage={itemsPerPage}
      baseUrl="/"
    />

    <!-- Newsletter footer -->
    <div class="newsletter-footer">
      <p class="newsletter-title">The best motion reels, weekly.</p>
      <div class="klaviyo-form-SffEDu"></div>
    </div>

  </main>
</Layout>

<style>
  .newsletter-footer {
    padding: 64px 32px 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    border-top: 1px solid #f0f0f0;
    text-align: center;
  }

  .newsletter-title {
    font-size: 28px;
    font-weight: 400;
    letter-spacing: -0.3px;
    color: #111;
    margin: 0;
  }
</style>

<style is:global>
  /* Klaviyo form width override */
  .newsletter-footer .klaviyo-form-SffEDu,
  .newsletter-footer .klaviyo-form-SffEDu .klaviyo-form,
  .newsletter-footer .klaviyo-form-SffEDu.klaviyo-form.form-version-cid-1 {
    width: 500px !important;
    max-width: 100%;
  }

  @media (max-width: 768px) {
    .newsletter-footer {
      padding: 48px 16px 64px;
    }

    .newsletter-footer .klaviyo-form-SffEDu,
    .newsletter-footer .klaviyo-form-SffEDu .klaviyo-form,
    .newsletter-footer .klaviyo-form-SffEDu.klaviyo-form.form-version-cid-1 {
      width: calc(100vw - 32px) !important;
    }
  }
</style>
