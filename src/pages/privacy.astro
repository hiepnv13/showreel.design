---
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---

<Layout
  title="Privacy Policy — Showreel.design"
  description="Privacy Policy for Showreel.design — how we collect, use, and protect your information."
  canonicalUrl="https://showreel.design/privacy"
>

  <main class="privacy-page">

    <section class="privacy-hero">
      <p class="privacy-eyebrow">Legal</p>
      <h1 class="privacy-title">Privacy Policy</h1>
      <p class="privacy-subtitle">Last updated: June 2026</p>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Overview</div>
      <div class="section-content">
        <p>
          Showreel.design ("we", "us", or "our") operates the website showreel.design.
          This page informs you of our policies regarding the collection, use, and
          disclosure of personal data when you use our service.
        </p>
        <p>
          By using Showreel.design, you agree to the collection and use of information
          in accordance with this policy.
        </p>
      </div>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Data we collect</div>
      <div class="section-content">
        <p>
          We collect minimal data to operate and improve the site. This includes:
        </p>
        <ul>
          <li>Email address — if you subscribe to our newsletter via the signup form</li>
          <li>Form submissions — if you submit a reel via the contact form on the About page</li>
          <li>Usage data — pages visited, time spent, browser type, and device information (collected anonymously via analytics tools)</li>
        </ul>
        <p>
          We do not sell, trade, or rent your personal information to third parties.
        </p>
      </div>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Third-party services</div>
      <div class="section-content">
        <p>We use the following third-party services that may collect data independently:</p>

        <div class="service-item">
          <p class="service-name">Google Analytics</p>
          <p>Used to understand how visitors interact with the site. Collects anonymized usage data. <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="privacy-link">Google Privacy Policy →</a></p>
        </div>

        <div class="service-item">
          <p class="service-name">Google AdSense</p>
          <p>Used to serve advertisements. Google may use cookies to personalize ads based on your browsing history. <a href="https://policies.google.com/technologies/ads" target="_blank" rel="noopener noreferrer" class="privacy-link">Google Ads Policy →</a></p>
        </div>

        <div class="service-item">
          <p class="service-name">Microsoft Clarity</p>
          <p>Used for session recording and heatmaps to improve user experience. Collects anonymized interaction data. <a href="https://privacy.microsoft.com/privacystatement" target="_blank" rel="noopener noreferrer" class="privacy-link">Microsoft Privacy Statement →</a></p>
        </div>

        <div class="service-item">
          <p class="service-name">Klaviyo</p>
          <p>Used to manage our newsletter. If you subscribe, your email address is stored in Klaviyo. You can unsubscribe at any time via the link in any email. <a href="https://www.klaviyo.com/legal/privacy-notice" target="_blank" rel="noopener noreferrer" class="privacy-link">Klaviyo Privacy Notice →</a></p>
        </div>

        <div class="service-item">
          <p class="service-name">Netlify</p>
          <p>Our hosting provider. Netlify may collect server logs and form submission data. <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener noreferrer" class="privacy-link">Netlify Privacy Policy →</a></p>
        </div>
      </div>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Cookies</div>
      <div class="section-content">
        <p>
          We use cookies and similar tracking technologies to track activity on our site.
          Cookies are small files stored on your device. You can instruct your browser
          to refuse all cookies or indicate when a cookie is being sent.
        </p>
        <p>
          Third-party services (Google Analytics, Google AdSense, Microsoft Clarity)
          may set their own cookies. You can opt out of Google's use of cookies by
          visiting Google's Ads Settings.
        </p>
      </div>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Your rights</div>
      <div class="section-content">
        <p>You have the right to:</p>
        <ul>
          <li>Access the personal data we hold about you</li>
          <li>Request correction or deletion of your data</li>
          <li>Unsubscribe from our newsletter at any time</li>
          <li>Opt out of analytics tracking via your browser settings</li>
        </ul>
        <p>
          To exercise any of these rights, contact us at:
        </p>
        <a href="mailto:hi.showreel.design@gmail.com" class="privacy-email">
          hi.showreel.design@gmail.com
          <svg viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </section>

    <div class="privacy-divider"></div>

    <section class="privacy-section">
      <div class="section-label">Changes</div>
      <div class="section-content">
        <p>
          We may update this Privacy Policy from time to time. Changes are effective
          immediately upon posting to this page. We encourage you to review this
          policy periodically.
        </p>
      </div>
    </section>

  </main>

</Layout>

<style>
  .privacy-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 80px 32px 100px;
  }

  .privacy-hero {
    padding-bottom: 64px;
  }

  .privacy-eyebrow {
    font-size: 9px;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #bbb;
    margin-bottom: 28px;
  }

  .privacy-title {
    font-size: clamp(32px, 5vw, 52px);
    font-weight: 400;
    letter-spacing: -1px;
    line-height: 1.15;
    color: #111;
    margin-bottom: 16px;
  }

  .privacy-subtitle {
    font-size: 13px;
    color: #bbb;
    letter-spacing: 0.2px;
  }

  .privacy-divider {
    width: 100%;
    height: 1px;
    background: #f0f0f0;
  }

  .privacy-section {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 40px;
    padding: 56px 0;
  }

  .section-label {
    font-size: 24px;
    color: #090909;
    padding-top: 4px;
    flex-shrink: 0;
    font-weight: 400;
  }

  .section-content {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .section-content p {
    font-size: 15px;
    line-height: 1.8;
    color: #555;
  }

  .section-content ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 20px;
  }

  .section-content ul li {
    font-size: 15px;
    line-height: 1.8;
    color: #555;
  }

  .service-item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px 0;
    border-bottom: 1px solid #f5f5f5;
  }

  .service-item:last-child {
    border-bottom: none;
  }

  .service-name {
    font-size: 14px;
    font-weight: 500;
    color: #222;
  }

  .privacy-link {
    color: #111;
    text-decoration: underline;
    text-decoration-color: #ddd;
    text-underline-offset: 3px;
    font-size: 13px;
    transition: text-decoration-color 0.2s;
  }

  .privacy-link:hover {
    text-decoration-color: #111;
  }

  .privacy-email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: #111;
    text-decoration: none;
    border-bottom: 1px solid #ddd;
    padding-bottom: 2px;
    width: fit-content;
    transition: border-color 0.2s, gap 0.2s;
  }

  .privacy-email:hover {
    border-color: #111;
    gap: 12px;
  }

  .privacy-email svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .privacy-page {
      padding: 48px 20px 72px;
    }

    .privacy-section {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 40px 0;
    }
  }
</style>
